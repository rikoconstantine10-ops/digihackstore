
<!DOCTYPE html>
<html lang="<%= t.lang %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= product.name %> - <%= settings.store_name %></title>
  <meta name="description" content="<%= (product.description ? product.description.replace(/<[^>]*>/g,'').slice(0,155) : product.name + ' - Tersedia di ' + (settings.store_name || 'Digihack Store')) %>">
  <% if(product.image) { %><link rel="preload" href="<%= product.image %>" as="image" fetchpriority="high"><% } %>
  <style>:root{--primary:#6c63ff;--primary-dark:#5a52d5;--secondary:#f8f9ff;--accent:#ff6584;--text:#2d3748;--text-light:#718096;--border:#e2e8f0;--white:#fff;--radius:12px;--shadow:0 4px 20px rgba(108,99,255,.12)}*{box-sizing:border-box;margin:0;padding:0}body{font-family:'Inter',-apple-system,sans-serif;background:#f7f8fc;color:var(--text)}a{text-decoration:none;color:inherit}img{max-width:100%}.navbar{background:#fff;box-shadow:0 2px 10px rgba(0,0,0,.08);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}.navbar-brand{font-size:1.4rem;font-weight:800;color:var(--primary)}.navbar-brand span{color:var(--accent)}.navbar-links{display:flex;gap:24px;align-items:center}.navbar-links a{font-size:.9rem;font-weight:500;color:var(--text-light)}.btn-nav{background:var(--primary);color:#fff!important;padding:8px 20px;border-radius:25px;font-weight:600!important}.btn-lang{background:transparent;color:var(--primary)!important;border:1px solid var(--primary);padding:6px 14px;border-radius:20px;font-size:.8rem;font-weight:600!important;cursor:pointer}.product-detail{display:grid;grid-template-columns:1fr 1fr;gap:48px;max-width:1000px;margin:40px auto;padding:0 24px}.product-detail img{border-radius:var(--radius);box-shadow:var(--shadow);width:100%;aspect-ratio:1/1;object-fit:contain;background:#f7f8fc}.product-info .category{color:var(--primary);font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:1px}.product-info h1{font-size:2rem;font-weight:800;margin:10px 0}.product-info .desc{color:var(--text-light);line-height:1.8;margin-bottom:24px}.price-block{background:var(--secondary);border-radius:12px;padding:20px;margin-bottom:24px}.price-block .price-now{font-size:2rem;font-weight:800;color:var(--primary)}.price-block .price-was{text-decoration:line-through;color:var(--text-light);font-size:.9rem}.badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px}.badge-new{background:#e0f2fe;color:#0284c7}.badge-hot{background:#fee2e2;color:#dc2626}.badge-sale{background:#fef3c7;color:#d97706}.badge-best{background:#dcfce7;color:#16a34a}.countdown{background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:.9rem;color:#c2410c;font-weight:600}.slot-bar{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:12px 16px;margin-bottom:16px}.slot-bar-full{background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:12px 16px;margin-bottom:16px}.slot-progress{background:#e5e7eb;border-radius:99px;height:8px;margin-top:8px;overflow:hidden}.slot-progress-fill{background:linear-gradient(90deg,#6c63ff,#a78bfa);height:100%;border-radius:99px;transition:width .4s}.btn-buy{width:100%;padding:16px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border:none;border-radius:12px;font-size:1.1rem;font-weight:700;cursor:pointer;transition:transform .2s}.btn-buy:hover{transform:translateY(-2px)}.btn-buy-disabled{width:100%;padding:16px;background:#e5e7eb;color:#9ca3af;border:none;border-radius:12px;font-size:1.1rem;font-weight:700;cursor:not-allowed}footer{background:var(--text);color:#a0aec0;padding:40px 24px;text-align:center;margin-top:60px}footer strong{color:#fff}.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;z-index:200}.hamburger span{display:block;width:24px;height:2.5px;background:var(--text);border-radius:2px;transition:transform .3s,opacity .3s}.hamburger.open span:nth-child(1){transform:translateY(7.5px) rotate(45deg)}.hamburger.open span:nth-child(2){opacity:0}.hamburger.open span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg)}.mobile-menu{display:none}@media(max-width:1024px){.hamburger{display:flex}.navbar-links{display:none!important}.mobile-menu{position:fixed;top:64px;left:0;right:0;background:#fff;z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,.15);border-top:2px solid var(--primary)}.mobile-menu.open{display:block}.mobile-menu a{display:block;padding:15px 20px;font-size:.95rem;font-weight:500;color:#2d3748;border-bottom:1px solid #f0f4f8;text-decoration:none}.mobile-menu a:last-child{border-bottom:none}}@media(max-width:768px){.product-detail{grid-template-columns:1fr;gap:24px}}.fee-summary{margin-top:12px;border-top:1px dashed #c4b5fd;padding-top:10px}.fee-toggle{background:none;border:none;color:var(--primary);font-size:.8rem;font-weight:600;cursor:pointer;padding:0;text-decoration:underline;text-underline-offset:2px;display:inline-flex;align-items:center;gap:4px}.fee-rows{display:none;margin-top:10px}.fee-rows.open{display:block}.fee-row{display:flex;justify-content:space-between;align-items:center;font-size:.82rem;padding:5px 0;border-bottom:1px solid #f0f4f8}.fee-row:last-of-type{border-bottom:none}.fee-row-label{color:var(--text-light)}.fee-row-val{font-weight:600;color:var(--text)}.fee-note{font-size:.72rem;color:#9ca3af;margin-top:8px;line-height:1.5;font-style:italic}.testimonials-wrap{max-width:1000px;margin:48px auto 0;padding:0 24px}.testimonials-head{text-align:center;margin-bottom:8px}.testimonials-head h2{font-size:1.4rem;font-weight:800}.testimonials-head p{color:var(--text-light);font-size:.9rem;margin-top:4px}.testimonials-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:24px}.tcard{background:#fff;border-radius:12px;padding:20px;box-shadow:0 2px 12px rgba(0,0,0,.06);border:1px solid var(--border)}.tcard-stars{color:#f59e0b;font-size:1rem;margin-bottom:8px;letter-spacing:1px}.tcard-text{font-size:.875rem;color:var(--text);line-height:1.65;margin-bottom:12px;font-style:italic}.tcard-author{font-size:.78rem;font-weight:700;color:var(--text-light)}.trust-row{display:flex;flex-wrap:wrap;justify-content:center;gap:20px;margin-top:24px;padding:18px 20px;background:#fff;border-radius:12px;border:1px solid var(--border)}.trust-item{display:flex;align-items:center;gap:6px;font-size:.82rem;color:var(--text);font-weight:600}@media(max-width:768px){.testimonials-grid{grid-template-columns:1fr;gap:12px}}@media(min-width:641px) and (max-width:900px){.testimonials-grid{grid-template-columns:repeat(2,1fr)}}</style>
  <link rel="preload" href="/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/css/style.css"></noscript>
  <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'"><noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
</head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">Digi<span>hack</span></a>
  <div class="navbar-links">
    <a href="/catalog"><%= t.nav_catalog %></a>
    <a href="/order/status"><%= t.nav_check_order %></a>
    <a href="?lang=<%= t.lang_toggle_url %>" class="btn-lang"><%= t.lang_toggle %></a>
    <a href="/catalog" class="btn-nav"><%= t.nav_shop %></a>
  </div>
  <button class="hamburger" id="hamburger" aria-label="Menu" onclick="toggleMenu()"><span></span><span></span><span></span></button>
</nav>
<div class="mobile-menu" id="mobileMenu">
  <a href="/catalog"><%= t.nav_catalog %></a>
  <a href="/order/status"><%= t.nav_check_order %></a>
  <a href="?lang=<%= t.lang_toggle_url %>"><%= t.lang_toggle %></a>
  <a href="/catalog"><%= t.nav_shop %></a>
</div>

<div style="max-width:1000px;margin:24px auto;padding:0 24px">
  <div style="font-size:0.85rem;color:var(--text-light);margin-bottom:24px">
    <a href="/"><%= t.home %></a> / <a href="/catalog"><%= t.breadcrumb_catalog %></a> / <a href="/catalog?category=<%= encodeURIComponent(product.category) %>"><%= product.category %></a> / <%= product.name %>
  </div>
</div>

<% const slotsFull = product.max_slots > 0 && (product.sold_slots || 0) >= product.max_slots; %>
<% const slotsLeft = product.max_slots > 0 ? product.max_slots - (product.sold_slots || 0) : null; %>
<% const slotPct = product.max_slots > 0 ? Math.min(100, Math.round((product.sold_slots || 0) / product.max_slots * 100)) : 0; %>

<div class="product-detail">
  <div>
    <% if(product.image) { %>
    <img src="<%= product.image %>" alt="<%= product.name %>" fetchpriority="high" width="480" height="480">
    <% } else { %>
    <div style="background:linear-gradient(135deg,#e0e7ff,#c7d2fe);border-radius:12px;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;font-size:6rem">📦</div>
    <% } %>
  </div>
  <div class="product-info">
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:8px">
      <span class="category"><%= product.category %></span>
      <% if(product.badge && !slotsFull) { %><span class="badge badge-<%= product.badge.toLowerCase() %>"><%= product.badge %></span><% } %>
      <% if(typeof salesCount !== 'undefined' && salesCount > 0) { %>
      <span style="display:inline-flex;align-items:center;gap:4px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:20px;padding:3px 10px;font-size:0.78rem;color:#166534;font-weight:600">🔥 <%= salesCount %> <%= t.sold %></span>
      <% } %>
    </div>
    <h1><%= product.name %></h1>
    <div class="desc"><%- product.description %></div>

    <% if(product.countdown_end) { %>
    <div class="countdown" id="countdown">⏰ Diskon berakhir dalam: <span id="timer">...</span></div>
    <% } %>

    <% if(product.max_slots > 0) { %>
    <% if(slotsFull) { %>
    <div class="slot-bar-full">
      <div style="display:flex;justify-content:space-between;font-size:.85rem;font-weight:600;color:#6b7280">
        <span>🚫 <%= t.slot_full %></span>
        <span><%= product.sold_slots %>/<%= product.max_slots %></span>
      </div>
      <div class="slot-progress"><div class="slot-progress-fill" style="width:100%;background:#e5e7eb"></div></div>
    </div>
    <% } else { %>
    <div class="slot-bar">
      <div style="display:flex;justify-content:space-between;font-size:.85rem;font-weight:600;color:#166534">
        <span>🎟️ <%= t.slot_remaining %>: <%= slotsLeft %></span>
        <span><%= product.sold_slots || 0 %>/<%= product.max_slots %> <%= t.sold %></span>
      </div>
      <div class="slot-progress"><div class="slot-progress-fill" style="width:<%= slotPct %>%"></div></div>
    </div>
    <% } %>
    <% } %>

    <div class="price-block">
      <% if(product.discount_price) { %>
      <div class="price-was"><%= t.normal_price %> Rp <%= product.price.toLocaleString('id-ID') %></div>
      <div class="price-now">Rp <%= product.discount_price.toLocaleString('id-ID') %></div>
      <div style="margin-top:6px"><span class="badge badge-sale"><%= t.save %> Rp <%= (product.price - product.discount_price).toLocaleString('id-ID') %></span></div>
      <% } else { %>
      <div class="price-now">Rp <%= product.price.toLocaleString('id-ID') %></div>
      <% } %>
      <div class="fee-summary">
        <button class="fee-toggle" id="feeToggle" onclick="toggleFeeRows()"><%= t.fee_toggle_show %></button>
        <div class="fee-rows" id="feeRows">
          <div class="fee-row"><span class="fee-row-label">📱 QRIS</span><span class="fee-row-val">+~Rp <span id="feeQRIS">—</span></span></div>
          <div class="fee-row"><span class="fee-row-label">🏦 Transfer Bank / Virtual Account</span><span class="fee-row-val">+Rp 4.000</span></div>
          <div class="fee-row"><span class="fee-row-label">👛 E-Wallet (GoPay / OVO / Dana)</span><span class="fee-row-val">+~Rp <span id="feeEwallet">—</span></span></div>
          <div class="fee-note"><%= t.fee_note %></div>
        </div>
      </div>
    </div>

    <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:0.85rem;color:#166534">
      ✅ <%= t.digital_delivery %><br>
      ✅ <%= t.payment_secure %><br>
      ✅ <%= t.payment_methods %>
    </div>

    <div style="display:flex;gap:10px">
      <% if(slotsFull) { %>
      <button class="btn-buy-disabled" disabled style="flex:1">🚫 <%= t.slot_full %></button>
      <% } else { %>
      <a href="/checkout/<%= product.slug %>" style="flex:1">
        <button class="btn-buy" style="width:100%">💎 <%= t.buy_now %> - Rp <%= (product.discount_price || product.price).toLocaleString('id-ID') %></button>
      </a>
      <% } %>
      <button id="wlBtn" onclick="toggleWishlistProduct()" style="width:52px;height:52px;border:2px solid var(--border);border-radius:12px;background:#fff;cursor:pointer;font-size:1.4rem;transition:all .2s;flex-shrink:0">🤍</button>
    </div>
  </div>
</div>

<section class="testimonials-wrap">
  <div class="testimonials-head">
    <h2><%= t.testimonials_title %></h2>
    <p><%= t.testimonials_subtitle %></p>
  </div>
  <div class="testimonials-grid">
    <div class="tcard">
      <div class="tcard-stars">⭐⭐⭐⭐⭐</div>
      <div class="tcard-text">"Produknya langsung dikirim ke email setelah bayar. Gak perlu nunggu lama, recommended banget!"</div>
      <div class="tcard-author">Reza A. — Jakarta ✅ Pembeli Terverifikasi</div>
    </div>
    <div class="tcard">
      <div class="tcard-stars">⭐⭐⭐⭐⭐</div>
      <div class="tcard-text">"Harganya terjangkau dan produknya original. Udah beli beberapa kali dan selalu puas. Toko terpercaya!"</div>
      <div class="tcard-author">Siti N. — Surabaya ✅ Pembeli Terverifikasi</div>
    </div>
    <div class="tcard">
      <div class="tcard-stars">⭐⭐⭐⭐⭐</div>
      <div class="tcard-text">"Proses beli gampang banget. Bayar, langsung dapat produknya. CS juga responsif kalau ada pertanyaan."</div>
      <div class="tcard-author">Budi S. — Bandung ✅ Pembeli Terverifikasi</div>
    </div>
  </div>
  <div class="trust-row">
    <span class="trust-item">🔒 <%= t.trust_payment %></span>
    <span class="trust-item">⚡ <%= t.trust_delivery %></span>
    <span class="trust-item">✅ <%= t.trust_verified %></span>
    <% if(typeof salesCount !== 'undefined' && salesCount > 0) { %>
    <span class="trust-item">🎯 <%= salesCount %>+ <%= t.trust_buyers %></span>
    <% } %>
  </div>
</section>

<footer style="margin-top:60px">
  <p>&copy; 2026 <strong><%= settings.store_name %></strong>. <%= t.footer_rights %></p>
</footer>

<script>
const _pid = '<%= product.id %>', _pname = '<%= product.name.replace(/'/g,"\\'") %>', _pimage = '<%= product.image || "" %>', _pprice = <%= product.discount_price || product.price %>, _pslug = '<%= product.slug %>';
function getWishlist() { try { return JSON.parse(localStorage.getItem('dg_wishlist')||'[]'); } catch(e) { return []; } }
function toggleWishlistProduct() {
  let wl = getWishlist();
  const idx = wl.findIndex(x => x.id == _pid);
  const btn = document.getElementById('wlBtn');
  if (idx >= 0) { wl.splice(idx,1); btn.textContent='🤍'; btn.style.borderColor='var(--border)'; }
  else { wl.push({id:_pid,name:_pname,image:_pimage,price:_pprice,slug:_pslug}); btn.textContent='❤️'; btn.style.borderColor='#e879b0'; }
  localStorage.setItem('dg_wishlist', JSON.stringify(wl));
}
(function(){ const wl=getWishlist(); const btn=document.getElementById('wlBtn'); if(btn&&wl.find(x=>x.id==_pid)){btn.textContent='❤️';btn.style.borderColor='#e879b0';} })();
</script>

<% if(product.countdown_end) { %>
<script>
const end = new Date('<%= product.countdown_end %>').getTime();
function tick() {
  const now = Date.now();
  const diff = end - now;
  if (diff <= 0) { document.getElementById('countdown').style.display='none'; return; }
  const h = Math.floor(diff/3600000);
  const m = Math.floor((diff%3600000)/60000);
  const s = Math.floor((diff%60000)/1000);
  document.getElementById('timer').textContent = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}
tick(); setInterval(tick, 1000);
</script>
<% } %>
<% if(settings.meta_pixel_id) { %>
<script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= settings.meta_pixel_id %>');fbq('track','PageView');fbq('track','ViewContent',{content_name:'<%= product.name.replace(/'/g,"\\'")||"" %>',content_ids:['<%= product.id %>'],content_type:'product',value:<%= product.discount_price || product.price %>,currency:'IDR'},<% if(typeof vcEventId !== "undefined" && vcEventId) { %>{eventID:'<%= vcEventId %>'}<% } else { %>{}<% } %>);</script>
<% } %>
<% if(settings && settings.ga4_id) { %><script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.ga4_id %>"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","<%= settings.ga4_id %>");</script><% } %>
<script>
(function(){
  var base=<%= product.discount_price || product.price %>;
  var qEl=document.getElementById('feeQRIS');
  var eEl=document.getElementById('feeEwallet');
  if(qEl) qEl.textContent=Math.max(500,Math.round(base*0.007)).toLocaleString('id-ID');
  if(eEl) eEl.textContent=Math.round(base*0.02).toLocaleString('id-ID');
})();
function toggleFeeRows(){
  var r=document.getElementById('feeRows');
  var btn=document.getElementById('feeToggle');
  r.classList.toggle('open');
  btn.textContent=r.classList.contains('open')?'<%= t.fee_toggle_hide %>':'<%= t.fee_toggle_show %>';
}
function toggleMenu(){const h=document.getElementById('hamburger'),m=document.getElementById('mobileMenu');h.classList.toggle('open');m.classList.toggle('open');}
document.addEventListener('click',function(e){const h=document.getElementById('hamburger'),m=document.getElementById('mobileMenu');if(h&&m&&!h.contains(e.target)&&!m.contains(e.target)){h.classList.remove('open');m.classList.remove('open');}});
window.addEventListener('scroll',function(){const h=document.getElementById('hamburger'),m=document.getElementById('mobileMenu');if(h)h.classList.remove('open');if(m)m.classList.remove('open');},{passive:true});
</script>
</body></html>
