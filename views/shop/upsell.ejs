<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Pembayaran Berhasil! - <%= settings.store_name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .success-hero { text-align:center; padding:48px 24px 32px; }
    .success-icon { font-size:4rem; margin-bottom:12px; }
    .success-title { font-size:2rem; font-weight:800; color:#16a34a; margin:0 0 8px; }
    .success-sub { color:var(--text-light); font-size:1rem; margin:0; }
    .order-summary { background:#f0fdf4; border:1px solid #bbf7d0; border-radius:14px; padding:20px 24px; max-width:480px; margin:0 auto 36px; }
    .order-summary h3 { margin:0 0 12px; font-size:0.9rem; font-weight:700; color:#166534; }
    .order-row { display:flex; justify-content:space-between; font-size:0.88rem; margin-bottom:6px; }
    .order-row:last-child { margin-bottom:0; font-weight:700; font-size:0.95rem; border-top:1px solid #bbf7d0; padding-top:8px; margin-top:4px; }
    .upsell-section { max-width:900px; margin:0 auto; padding:0 24px 48px; }
    .upsell-title { font-size:1.2rem; font-weight:800; margin-bottom:20px; text-align:center; }
    .upsell-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(240px,1fr)); gap:20px; }
    .upsell-card { background:#fff; border-radius:14px; box-shadow:var(--shadow); overflow:hidden; border:1px solid var(--border); transition:transform .15s,box-shadow .15s; }
    .upsell-card:hover { transform:translateY(-3px); box-shadow:0 8px 30px rgba(0,0,0,0.1); }
    .upsell-card img { width:100%; aspect-ratio:4/3; object-fit:cover; }
    .upsell-card-ph { width:100%; aspect-ratio:4/3; background:linear-gradient(135deg,#e0e7ff,#c7d2fe); display:flex; align-items:center; justify-content:center; font-size:3rem; }
    .upsell-card-body { padding:16px; }
    .upsell-card-name { font-weight:700; font-size:0.92rem; margin-bottom:8px; line-height:1.3; }
    .upsell-card-price { font-size:1.05rem; font-weight:800; color:var(--primary); margin-bottom:12px; }
    .upsell-card-price-was { font-size:0.78rem; color:var(--text-light); text-decoration:line-through; margin-bottom:2px; }
    .btn-upsell { display:block; width:100%; padding:10px; background:var(--primary); color:#fff; border:none; border-radius:8px; font-weight:700; font-size:0.88rem; cursor:pointer; text-align:center; text-decoration:none; box-sizing:border-box; }
    .btn-upsell:hover { background:#4338ca; }
    .cta-area { text-align:center; margin-bottom:32px; }
    .btn-order-status { display:inline-block; padding:12px 28px; background:#e0e7ff; color:var(--primary); border-radius:10px; font-weight:700; font-size:0.9rem; text-decoration:none; }
    .btn-order-status:hover { background:#c7d2fe; }
  </style>
</head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">Digi<span>hack</span></a>
  <div class="navbar-links">
    <a href="/catalog">Catalog</a>
    <a href="/order/status">Cek Order</a>
    <a href="/catalog" class="btn-nav">Belanja Sekarang</a>
  </div>
</nav>

<div class="success-hero">
  <div class="success-icon">✅</div>
  <h1 class="success-title">Pembayaran Berhasil!</h1>
  <p class="success-sub">Terima kasih! Produk digital akan segera dikirim ke email kamu.</p>
</div>

<div style="max-width:900px;margin:0 auto;padding:0 24px">
  <div class="order-summary">
    <h3>📋 Ringkasan Order</h3>
    <div class="order-row"><span>Produk</span><span><%= order.product_name %></span></div>
    <div class="order-row"><span>Ref. Order</span><span style="font-family:monospace"><%= order.ref_kode %></span></div>
    <div class="order-row"><span>Email</span><span><%= order.customer_email %></span></div>
    <div class="order-row"><span>Total Bayar</span><span style="color:#16a34a">Rp <%= order.amount.toLocaleString('id-ID') %></span></div>
  </div>
</div>

<div class="cta-area">
  <a href="/order/status?ref=<%= order.ref_kode %>" class="btn-order-status">📦 Lihat Status Order</a>
</div>

<% if(products && products.length > 0) { %>
<div class="upsell-section">
  <div class="upsell-title">🛍️ Produk Lain yang Mungkin Kamu Suka</div>
  <div class="upsell-grid">
    <% products.forEach(p => { %>
    <div class="upsell-card">
      <% if(p.image) { %>
      <img src="<%= p.image %>" alt="<%= p.name %>">
      <% } else { %>
      <div class="upsell-card-ph">📦</div>
      <% } %>
      <div class="upsell-card-body">
        <div class="upsell-card-name"><%= p.name %></div>
        <% if(p.discount_price) { %>
        <div class="upsell-card-price-was">Rp <%= p.price.toLocaleString('id-ID') %></div>
        <div class="upsell-card-price">Rp <%= p.discount_price.toLocaleString('id-ID') %></div>
        <% } else { %>
        <div class="upsell-card-price">Rp <%= p.price.toLocaleString('id-ID') %></div>
        <% } %>
        <a href="/checkout/<%= p.slug %>" class="btn-upsell">💎 Beli Sekarang</a>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<% } %>

<footer style="text-align:center;padding:24px;color:var(--text-light);font-size:0.85rem;border-top:1px solid var(--border)">
  &copy; 2026 <strong><%= settings.store_name %></strong>. All rights reserved.
</footer>
</body>
</html>
