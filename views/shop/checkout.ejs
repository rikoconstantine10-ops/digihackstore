
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Checkout - <%= product.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <% if(settings.meta_pixel_id) { %><script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= settings.meta_pixel_id %>');fbq('track','InitiateCheckout',{value:<%= product.discount_price || product.price %>,currency:'IDR'});</script><% } %>
<% if(settings && settings.ga4_id) { %><script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.ga4_id %>"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","<%= settings.ga4_id %>");</script><% } %></head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">Digi<span>hack</span></a>
  <div class="navbar-links"><a href="/catalog">Catalog</a></div>
</nav>

<div class="checkout-wrap">
  <div style="text-align:center;margin:32px 0 24px">
    <div style="font-size:2rem;margin-bottom:8px">💳</div>
    <h1 style="font-size:1.5rem;font-weight:800">Checkout</h1>
    <p style="color:var(--text-light);font-size:0.9rem">Isi data diri kamu untuk melanjutkan</p>
  </div>

  <div class="checkout-card">
    <div class="checkout-product">
      <% if(product.image) { %>
      <img src="<%= product.image %>" alt="<%= product.name %>">
      <% } else { %>
      <div style="width:60px;height:60px;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.5rem">📦</div>
      <% } %>
      <div>
        <div class="name"><%= product.name %></div>
        <div class="price">Rp <%= (product.discount_price || product.price).toLocaleString('id-ID') %></div>
      </div>
    </div>

    <% if(error) { %><div class="error-msg">❌ <%= error %></div><% } %>

    <form method="POST" action="/checkout/<%= product.slug %>">
      <div class="form-group">
        <label>Nama Lengkap *</label>
        <input type="text" name="name" placeholder="John Doe" required>
      </div>
      <div class="form-group">
        <label>Email *</label>
        <input type="email" name="email" placeholder="email@kamu.com" required>
      </div>
      <div class="form-group">
        <label>No. WhatsApp *</label>
        <input type="tel" name="phone" placeholder="08123456789" required>
      </div>

      <div class="form-group">
        <label>Metode Pembayaran *</label>
        <div class="payment-methods">
          <label class="payment-option">
            <input type="radio" name="channel" value="QRIS" required>
            <div style="font-size:1.5rem">📱</div>
            <div class="pm-name">QRIS</div>
            <div class="pm-fee">Fee 0.7%</div>
          </label>
          <label class="payment-option">
            <input type="radio" name="channel" value="BRIVA">
            <div style="font-size:1.5rem">🏦</div>
            <div class="pm-name">BRI VA</div>
            <div class="pm-fee">Fee Rp 3.000</div>
          </label>
          <label class="payment-option">
            <input type="radio" name="channel" value="BCAVA">
            <div style="font-size:1.5rem">🏦</div>
            <div class="pm-name">BCA VA</div>
            <div class="pm-fee">Fee Rp 4.500</div>
          </label>
          <label class="payment-option">
            <input type="radio" name="channel" value="MANDIRIVA">
            <div style="font-size:1.5rem">🏦</div>
            <div class="pm-name">Mandiri VA</div>
            <div class="pm-fee">Fee Rp 3.000</div>
          </label>
          <label class="payment-option">
            <input type="radio" name="channel" value="BNIVA">
            <div style="font-size:1.5rem">🏦</div>
            <div class="pm-name">BNI VA</div>
            <div class="pm-fee">Fee Rp 3.500</div>
          </label>
          <label class="payment-option">
            <input type="radio" name="channel" value="DANA">
            <div style="font-size:1.5rem">💳</div>
            <div class="pm-name">DANA</div>
            <div class="pm-fee">Fee 1.67%</div>
          </label>
          <label class="payment-option">
            <input type="radio" name="channel" value="Shopee Pay">
            <div style="font-size:1.5rem">🛒</div>
            <div class="pm-name">ShopeePay</div>
            <div class="pm-fee">Fee 4%</div>
          </label>
          <label class="payment-option">
            <input type="radio" name="channel" value="ALFAMART">
            <div style="font-size:1.5rem">🏪</div>
            <div class="pm-name">Alfamart</div>
            <div class="pm-fee">Fee Rp 3.500</div>
          </label>
        </div>
      </div>

      <div style="background:#f8f9ff;border-radius:8px;padding:14px;margin-bottom:20px;font-size:0.85rem">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px">
          <span style="color:var(--text-light)">Harga produk</span>
          <span style="font-weight:600" id="base-price-display">Rp <%= (product.discount_price || product.price).toLocaleString('id-ID') %></span>
        </div>
        <div style="display:flex;justify-content:space-between;margin-bottom:6px">
          <span style="color:var(--text-light)">Biaya payment</span>
          <span id="fee-display" style="color:var(--text-light)">— Pilih metode</span>
        </div>
        <hr style="border:none;border-top:1px solid var(--border);margin:8px 0">
        <div style="display:flex;justify-content:space-between;font-weight:800;font-size:1rem">
          <span>Total</span>
          <span style="color:var(--primary)" id="total-display">Rp <%= (product.discount_price || product.price).toLocaleString('id-ID') %></span>
        </div>
      </div>

      <button type="submit" class="btn-submit">🔒 Bayar Sekarang</button>
    </form>
  </div>

  <!-- Security Badges -->
  <div style="margin-top:24px;display:flex;flex-direction:column;align-items:center;gap:14px">
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:center">
      <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #e2e8f0;border-radius:30px;padding:7px 14px;font-size:0.78rem;font-weight:600;color:#374151;box-shadow:0 1px 4px rgba(0,0,0,0.06)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Transaksi Aman & Terenkripsi
      </div>
      <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #e2e8f0;border-radius:30px;padding:7px 14px;font-size:0.78rem;font-weight:600;color:#374151;box-shadow:0 1px 4px rgba(0,0,0,0.06)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        SSL Protected
      </div>
      <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #e2e8f0;border-radius:30px;padding:7px 14px;font-size:0.78rem;font-weight:600;color:#374151;box-shadow:0 1px 4px rgba(0,0,0,0.06)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Produk Terkirim Otomatis
      </div>
    </div>
    <div style="font-size:0.75rem;color:#94a3b8;text-align:center">
      Powered by <strong style="color:#7c3aed">Violet Media Pay</strong> · Pembayaran diproses secara aman
    </div>
  </div>
</div>

<script>
const BASE_PRICE = <%= product.discount_price || product.price %>;

const FEE_CONFIG = {
  'QRIS':       { type: 'pct', value: 0.007,  label: '0.7%' },
  'BRIVA':      { type: 'flat', value: 3000,   label: 'Rp 3.000' },
  'BCAVA':      { type: 'flat', value: 4500,   label: 'Rp 4.500' },
  'MANDIRIVA':  { type: 'flat', value: 3000,   label: 'Rp 3.000' },
  'BNIVA':      { type: 'flat', value: 3500,   label: 'Rp 3.500' },
  'DANA':       { type: 'pct', value: 0.0167,  label: '1.67%' },
  'Shopee Pay': { type: 'pct', value: 0.04,    label: '4%' },
  'ALFAMART':   { type: 'flat', value: 3500,   label: 'Rp 3.500' },
};

function formatRp(n) {
  return 'Rp ' + Math.round(n).toLocaleString('id-ID');
}

function updateTotal() {
  const selected = document.querySelector('input[name="channel"]:checked');
  const feeEl = document.getElementById('fee-display');
  const totalEl = document.getElementById('total-display');

  if (!selected) {
    feeEl.textContent = '— Pilih metode';
    feeEl.style.color = 'var(--text-light)';
    totalEl.textContent = formatRp(BASE_PRICE);
    return;
  }

  const cfg = FEE_CONFIG[selected.value];
  if (!cfg) return;

  const fee = cfg.type === 'pct' ? BASE_PRICE * cfg.value : cfg.value;
  const total = BASE_PRICE + fee;

  feeEl.textContent = formatRp(fee) + ' (' + cfg.label + ')';
  feeEl.style.color = '#374151';
  totalEl.textContent = formatRp(total);
}

document.querySelectorAll('input[name="channel"]').forEach(r => r.addEventListener('change', updateTotal));
</script>

<footer style="margin-top:60px">
  <p>&copy; 2026 <strong><%= settings.store_name %></strong></p>
</footer>
</body></html>
