
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Checkout - <%= product.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <% if(settings.meta_pixel_id) { %><script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= settings.meta_pixel_id %>');fbq('track','InitiateCheckout',{value:<%= product.discount_price || product.price %>,currency:'IDR'});</script><% } %>
  <% if(settings && settings.ga4_id) { %><script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.ga4_id %>"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","<%= settings.ga4_id %>");</script><% } %>
  <style>
    .pm-group { margin-bottom: 20px; }
    .pm-group-label {
      font-size: 0.7rem; font-weight: 700; color: var(--text-light);
      text-transform: uppercase; letter-spacing: 0.07em;
      margin-bottom: 8px; padding-left: 2px;
    }
    .payment-methods { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
    @media (max-width: 400px) { .payment-methods { grid-template-columns: repeat(2, 1fr); } }
    .payment-option { position: relative; cursor: pointer; }
    .payment-option input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
    .pm-card {
      border: 2px solid var(--border); border-radius: 10px;
      padding: 10px 6px 8px; text-align: center;
      transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
      background: #fff; display: flex; flex-direction: column;
      align-items: center; gap: 5px; min-height: 82px; justify-content: center;
    }
    .payment-option input:checked + .pm-card {
      border-color: var(--primary); background: #f5f3ff;
      box-shadow: 0 2px 10px rgba(102,126,234,0.2);
    }
    .payment-option:hover .pm-card { border-color: #a5b4fc; }
    .pm-logo { height: 28px; max-width: 72px; object-fit: contain; display: block; }
    .pm-name { font-size: 0.72rem; font-weight: 700; color: var(--text-dark); line-height: 1.2; }
    .pm-fee { font-size: 0.64rem; color: var(--text-light); line-height: 1.2; }
  </style>
</head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">Digi<span>hack</span></a>
  <div class="navbar-links"><a href="/catalog">Catalog</a></div>
</nav>

<div class="checkout-wrap">
  <div style="text-align:center;margin:32px 0 24px">
    <div style="font-size:2rem;margin-bottom:8px">💳</div>
    <h1 style="font-size:1.5rem;font-weight:800">Checkout</h1>
    <p style="color:var(--text-light);font-size:0.9rem">Isi data diri kamu untuk melanjutkan</p>
  </div>

  <div class="checkout-card">
    <div class="checkout-product">
      <% if(product.image) { %>
      <img src="<%= product.image %>" alt="<%= product.name %>">
      <% } else { %>
      <div style="width:60px;height:60px;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.5rem">📦</div>
      <% } %>
      <div>
        <div class="name"><%= product.name %></div>
        <div class="price">Rp <%= (product.discount_price || product.price).toLocaleString('id-ID') %></div>
      </div>
    </div>

    <% if(error) { %><div class="error-msg">❌ <%= error %></div><% } %>

    <form method="POST" action="/checkout/<%= product.slug %>">
      <div class="form-group">
        <label>Nama Lengkap *</label>
        <input type="text" name="name" placeholder="John Doe" required>
      </div>
      <div class="form-group">
        <label>Email *</label>
        <input type="email" name="email" placeholder="email@kamu.com" required>
      </div>
      <div class="form-group">
        <label>No. WhatsApp *</label>
        <input type="tel" name="phone" placeholder="08123456789" required>
      </div>

      <div class="form-group">
        <label>Metode Pembayaran *</label>

        <!-- QRIS -->
        <div class="pm-group">
          <div class="pm-group-label">QRIS</div>
          <div class="payment-methods">
            <label class="payment-option">
              <input type="radio" name="channel" value="QRIS" required>
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/qris.png" alt="QRIS">
                <div class="pm-name">QRIS</div>
                <div class="pm-fee">0.7% + Rp 1.000</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="QRIS1">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/qris.png" alt="QRIS 1">
                <div class="pm-name">QRIS 1</div>
                <div class="pm-fee">0.7% + Rp 500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="QRIS2">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/qris.png" alt="QRIS 2">
                <div class="pm-name">QRIS 2</div>
                <div class="pm-fee">0.8% + Rp 200</div>
              </div>
            </label>
          </div>
        </div>

        <!-- E-Wallet -->
        <div class="pm-group">
          <div class="pm-group-label">E-Wallet</div>
          <div class="payment-methods">
            <label class="payment-option">
              <input type="radio" name="channel" value="DANA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/dana.webp" alt="DANA">
                <div class="pm-name">DANA</div>
                <div class="pm-fee">1.67% + Rp 1.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="OVO">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/ovo.webp" alt="OVO">
                <div class="pm-name">OVO</div>
                <div class="pm-fee">3.03% + Rp 500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="Shopee Pay">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/logo-shopeepay.png" alt="ShopeePay">
                <div class="pm-name">ShopeePay</div>
                <div class="pm-fee">4% + Rp 500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="Link Aja">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/link-aja.png" alt="LinkAja">
                <div class="pm-name">LinkAja</div>
                <div class="pm-fee">1.67% + Rp 500</div>
              </div>
            </label>
          </div>
        </div>

        <!-- Virtual Account -->
        <div class="pm-group">
          <div class="pm-group-label">Virtual Account</div>
          <div class="payment-methods">
            <label class="payment-option">
              <input type="radio" name="channel" value="BRIVA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/logo-bri.png" alt="BRI VA">
                <div class="pm-name">BRI VA</div>
                <div class="pm-fee">Rp 3.000</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="BCAVA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/logo-bca.png" alt="BCA VA">
                <div class="pm-name">BCA VA</div>
                <div class="pm-fee">Rp 4.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="MANDIRIVA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/logo-mandiri.png" alt="Mandiri VA">
                <div class="pm-name">Mandiri VA</div>
                <div class="pm-fee">Rp 3.000</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="BNIVA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/logo-bni.png" alt="BNI VA">
                <div class="pm-name">BNI VA</div>
                <div class="pm-fee">Rp 3.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="BSI">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/bsi-syariah-indonesia.jpg" alt="BSI VA">
                <div class="pm-name">BSI VA</div>
                <div class="pm-fee">Rp 3.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="CIMBNIAGA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/logo-cimbniaga.png" alt="CIMB VA">
                <div class="pm-name">CIMB VA</div>
                <div class="pm-fee">Rp 3.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="DANAMON">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/danamon-logo.png" alt="Danamon VA">
                <div class="pm-name">Danamon VA</div>
                <div class="pm-fee">Rp 2.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="PERMATAVA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/logo-permata.png" alt="Permata VA">
                <div class="pm-name">Permata VA</div>
                <div class="pm-fee">Rp 2.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="MAYBANK">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/myBank-va.png" alt="Maybank VA">
                <div class="pm-name">Maybank VA</div>
                <div class="pm-fee">Rp 4.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="BNCVA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/Bank-Neo-Commerce.png" alt="BNC VA">
                <div class="pm-name">BNC VA</div>
                <div class="pm-fee">Rp 4.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="OCBC">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/OCBC-bank.png" alt="OCBC VA">
                <div class="pm-name">OCBC VA</div>
                <div class="pm-fee">Rp 2.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="SINARMAS">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/sinarmas%20bank.png" alt="Sinarmas VA">
                <div class="pm-name">Sinarmas VA</div>
                <div class="pm-fee">Rp 2.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="PANIN">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/Panin_Bank2.png" alt="Panin VA">
                <div class="pm-name">Panin VA</div>
                <div class="pm-fee">Rp 3.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="SAMPOERNAVA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/sampoernava.jpg" alt="Sahabat VA">
                <div class="pm-name">Sahabat VA</div>
                <div class="pm-fee">Rp 2.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="ATMBERSAMA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/ATM_Bersama.png" alt="ATM Bersama">
                <div class="pm-name">ATM Bersama</div>
                <div class="pm-fee">Rp 4.500</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="ARTAGRAHA">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/Bank_Artha_Graha_Internasional.png" alt="Artagraha VA">
                <div class="pm-name">Artagraha VA</div>
                <div class="pm-fee">Rp 2.500</div>
              </div>
            </label>
          </div>
        </div>

        <!-- Gerai Retail -->
        <div class="pm-group">
          <div class="pm-group-label">Gerai Retail</div>
          <div class="payment-methods">
            <label class="payment-option">
              <input type="radio" name="channel" value="ALFAMART">
              <div class="pm-card">
                <img class="pm-logo" src="https://violetmediapay.com/assets/img/pembayaran/logo-alfamart.png" alt="Alfamart">
                <div class="pm-name">Alfamart</div>
                <div class="pm-fee">Rp 3.500</div>
              </div>
            </label>
          </div>
        </div>
      </div>

      <div style="background:#f8f9ff;border-radius:8px;padding:14px;margin-bottom:20px;font-size:0.85rem">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px">
          <span style="color:var(--text-light)">Harga produk</span>
          <span style="font-weight:600">Rp <%= (product.discount_price || product.price).toLocaleString('id-ID') %></span>
        </div>
        <div style="display:flex;justify-content:space-between;margin-bottom:6px">
          <span style="color:var(--text-light)">Biaya payment</span>
          <span id="fee-display" style="color:var(--text-light)">— Pilih metode</span>
        </div>
        <hr style="border:none;border-top:1px solid var(--border);margin:8px 0">
        <div style="display:flex;justify-content:space-between;font-weight:800;font-size:1rem">
          <span>Total</span>
          <span style="color:var(--primary)" id="total-display">Rp <%= (product.discount_price || product.price).toLocaleString('id-ID') %></span>
        </div>
      </div>

      <button type="submit" class="btn-submit">🔒 Bayar Sekarang</button>
    </form>
  </div>

  <!-- Security Badges -->
  <div style="margin-top:24px;display:flex;flex-direction:column;align-items:center;gap:14px">
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:center">
      <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #e2e8f0;border-radius:30px;padding:7px 14px;font-size:0.78rem;font-weight:600;color:#374151;box-shadow:0 1px 4px rgba(0,0,0,0.06)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Transaksi Aman & Terenkripsi
      </div>
      <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #e2e8f0;border-radius:30px;padding:7px 14px;font-size:0.78rem;font-weight:600;color:#374151;box-shadow:0 1px 4px rgba(0,0,0,0.06)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        SSL Protected
      </div>
      <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #e2e8f0;border-radius:30px;padding:7px 14px;font-size:0.78rem;font-weight:600;color:#374151;box-shadow:0 1px 4px rgba(0,0,0,0.06)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Produk Terkirim Otomatis
      </div>
    </div>
  </div>
</div>

<script>
const BASE_PRICE = <%= product.discount_price || product.price %>;

const FEE_CONFIG = {
  'QRIS':        { type: 'pct_flat', pct: 0.007,   flat: 1000, label: '0.7% + Rp 1.000' },
  'QRIS1':       { type: 'pct_flat', pct: 0.007,   flat: 500,  label: '0.7% + Rp 500' },
  'QRIS2':       { type: 'pct_flat', pct: 0.008,   flat: 200,  label: '0.8% + Rp 200' },
  'DANA':        { type: 'pct_flat', pct: 0.0167,  flat: 1500, label: '1.67% + Rp 1.500' },
  'OVO':         { type: 'pct_flat', pct: 0.0303,  flat: 500,  label: '3.03% + Rp 500' },
  'Shopee Pay':  { type: 'pct_flat', pct: 0.04,    flat: 500,  label: '4% + Rp 500' },
  'Link Aja':    { type: 'pct_flat', pct: 0.0167,  flat: 500,  label: '1.67% + Rp 500' },
  'BRIVA':       { type: 'flat', value: 3000,  label: 'Rp 3.000' },
  'BCAVA':       { type: 'flat', value: 4500,  label: 'Rp 4.500' },
  'MANDIRIVA':   { type: 'flat', value: 3000,  label: 'Rp 3.000' },
  'BNIVA':       { type: 'flat', value: 3500,  label: 'Rp 3.500' },
  'BSI':         { type: 'flat', value: 3500,  label: 'Rp 3.500' },
  'CIMBNIAGA':   { type: 'flat', value: 3500,  label: 'Rp 3.500' },
  'DANAMON':     { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'PERMATAVA':   { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'MAYBANK':     { type: 'flat', value: 4500,  label: 'Rp 4.500' },
  'BNCVA':       { type: 'flat', value: 4500,  label: 'Rp 4.500' },
  'OCBC':        { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'SINARMAS':    { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'PANIN':       { type: 'flat', value: 3500,  label: 'Rp 3.500' },
  'SAMPOERNAVA': { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'ATMBERSAMA':  { type: 'flat', value: 4500,  label: 'Rp 4.500' },
  'ARTAGRAHA':   { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'ALFAMART':    { type: 'flat', value: 3500,  label: 'Rp 3.500' },
};

function formatRp(n) {
  return 'Rp ' + Math.round(n).toLocaleString('id-ID');
}

function updateTotal() {
  const selected = document.querySelector('input[name="channel"]:checked');
  const feeEl = document.getElementById('fee-display');
  const totalEl = document.getElementById('total-display');

  if (!selected) {
    feeEl.textContent = '— Pilih metode';
    feeEl.style.color = 'var(--text-light)';
    totalEl.textContent = formatRp(BASE_PRICE);
    return;
  }

  const cfg = FEE_CONFIG[selected.value];
  if (!cfg) return;

  const fee = cfg.type === 'pct_flat'
    ? Math.round(BASE_PRICE * cfg.pct) + cfg.flat
    : cfg.value;
  const total = BASE_PRICE + fee;

  feeEl.textContent = formatRp(fee) + ' (' + cfg.label + ')';
  feeEl.style.color = '#374151';
  totalEl.textContent = formatRp(total);
}

document.querySelectorAll('input[name="channel"]').forEach(r => r.addEventListener('change', updateTotal));
</script>

<footer style="margin-top:60px">
  <p>&copy; 2026 <strong><%= settings.store_name %></strong></p>
</footer>
</body></html>
