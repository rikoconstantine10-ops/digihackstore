<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Checkout - <%= product.name %></title>
  <style>:root{--primary:#6c63ff;--primary-dark:#5a52d5;--secondary:#f8f9ff;--text:#2d3748;--text-light:#718096;--border:#e2e8f0;--white:#fff;--radius:12px;--shadow:0 4px 20px rgba(108,99,255,.12)}*{box-sizing:border-box;margin:0;padding:0}body{font-family:'Inter',-apple-system,sans-serif;background:#f7f8fc;color:var(--text)}a{text-decoration:none;color:inherit}img{max-width:100%}.navbar{background:#fff;box-shadow:0 2px 10px rgba(0,0,0,.08);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}.navbar-brand{font-size:1.4rem;font-weight:800;color:var(--primary)}.navbar-brand span{color:#ff6584}.navbar-links{display:flex;gap:24px;align-items:center}.navbar-links a{font-size:.9rem;font-weight:500;color:var(--text-light)}.btn-nav{background:var(--primary);color:#fff!important;padding:8px 20px;border-radius:25px;font-weight:600!important}.checkout-wrap{max-width:480px;margin:40px auto;padding:0 16px}.checkout-card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow);padding:32px}.checkout-product{background:var(--secondary);border-radius:8px;padding:16px;margin-bottom:24px;display:flex;gap:12px;align-items:center}.checkout-product img{width:60px;height:60px;object-fit:cover;border-radius:8px}.checkout-product .name{font-weight:700;font-size:.95rem}.checkout-product .price{color:var(--primary);font-weight:800;font-size:1.1rem}.form-group{margin-bottom:16px}.form-group label{display:block;font-size:.85rem;font-weight:600;margin-bottom:6px;color:var(--text)}.form-group input{width:100%;padding:11px 14px;border:1px solid var(--border);border-radius:8px;font-size:.95rem;outline:none;transition:border .2s}.form-group input:focus{border-color:var(--primary)}.btn-submit{width:100%;padding:15px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border:none;border-radius:12px;font-size:1rem;font-weight:700;cursor:pointer}.error-msg{background:#fee2e2;color:#dc2626;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:.9rem}footer{background:var(--text);color:#a0aec0;padding:40px 24px;text-align:center;margin-top:60px}footer strong{color:#fff}</style>
  <link rel="preload" href="/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/css/style.css"></noscript>
  <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'"><noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
  <% if(settings.meta_pixel_id) { %><script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= settings.meta_pixel_id %>');fbq('track','PageView');fbq('track','InitiateCheckout',{content_ids:['<%= product.id %>'],content_type:'product',content_name:'<%= product.name.replace(/'/g,"\\'")||"" %>',value:<%= product.discount_price || product.price %>,currency:'IDR',num_items:1},<% if(typeof icEventId !== "undefined" && icEventId) { %>{eventID:'<%= icEventId %>'}<% } else { %>{}<% } %>);</script><% } %>
  <% if(settings && settings.ga4_id) { %><script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.ga4_id %>"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","<%= settings.ga4_id %>");</script><% } %>
</head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">Digi<span>hack</span></a>
  <div class="navbar-links"><a href="/catalog">Catalog</a></div>
</nav>

<div class="checkout-wrap">
  <div style="text-align:center;margin:32px 0 24px">
    <div style="font-size:2rem;margin-bottom:8px">🛒</div>
    <h1 style="font-size:1.5rem;font-weight:800">Data Diri</h1>
    <p style="color:var(--text-light);font-size:0.9rem">Isi informasi kamu untuk melanjutkan pembelian</p>
    <div id="checkout-timer" style="display:inline-flex;align-items:center;gap:6px;background:#fff3cd;border:1px solid #ffc107;border-radius:20px;padding:5px 14px;font-size:0.8rem;font-weight:700;color:#856404;margin-top:8px">
      ⏱ Sesi berakhir dalam <span id="timer-display">15:00</span>
    </div>
  </div>

  <!-- Step indicator -->
  <div style="display:flex;justify-content:center;align-items:center;gap:0;margin-bottom:28px">
    <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
      <div style="width:32px;height:32px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700">1</div>
      <span style="font-size:0.7rem;font-weight:600;color:var(--primary)">Data Diri</span>
    </div>
    <div style="width:48px;height:2px;background:#e2e8f0;margin-bottom:20px"></div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
      <div style="width:32px;height:32px;border-radius:50%;background:#e2e8f0;color:#94a3b8;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700">2</div>
      <span style="font-size:0.7rem;font-weight:600;color:#94a3b8">Add-on</span>
    </div>
    <div style="width:48px;height:2px;background:#e2e8f0;margin-bottom:20px"></div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
      <div style="width:32px;height:32px;border-radius:50%;background:#e2e8f0;color:#94a3b8;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700">3</div>
      <span style="font-size:0.7rem;font-weight:600;color:#94a3b8">Pembayaran</span>
    </div>
  </div>

  <div class="checkout-card">
    <div class="checkout-product">
      <% if(product.image) { %>
      <img src="<%= product.image %>" alt="<%= product.name %>">
      <% } else { %>
      <div style="width:60px;height:60px;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.5rem">📦</div>
      <% } %>
      <div>
        <div class="name"><%= product.name %></div>
        <div class="price">Rp <%= (product.discount_price || product.price).toLocaleString('id-ID') %></div>
      </div>
    </div>

    <% if(error) { %><div class="error-msg">❌ <%= error %></div><% } %>

    <form method="POST" action="/checkout/<%= product.slug %>">
      <div class="form-group">
        <label>Nama Lengkap *</label>
        <input type="text" name="name" placeholder="John Doe" required>
      </div>
      <div class="form-group">
        <label>Email *</label>
        <input type="email" name="email" placeholder="email@kamu.com" required>
      </div>
      <div class="form-group">
        <label>No. WhatsApp *</label>
        <input type="tel" name="phone" placeholder="08123456789" required>
      </div>
      <div class="form-group">
        <label>Domisili *</label>
        <input type="text" name="domisili" placeholder="Kota / Kabupaten" required>
      </div>

      <button type="submit" class="btn-submit">Lanjutkan →</button>
    </form>
  </div>

  <div style="margin-top:24px;display:flex;flex-direction:column;align-items:center;gap:14px">
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:center">
      <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #e2e8f0;border-radius:30px;padding:7px 14px;font-size:0.78rem;font-weight:600;color:#374151;box-shadow:0 1px 4px rgba(0,0,0,0.06)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Transaksi Aman & Terenkripsi
      </div>
      <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #e2e8f0;border-radius:30px;padding:7px 14px;font-size:0.78rem;font-weight:600;color:#374151;box-shadow:0 1px 4px rgba(0,0,0,0.06)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        SSL Protected
      </div>
      <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #e2e8f0;border-radius:30px;padding:7px 14px;font-size:0.78rem;font-weight:600;color:#374151;box-shadow:0 1px 4px rgba(0,0,0,0.06)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Produk Terkirim Otomatis
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const KEY = 'checkout_timer_<%= product.slug %>';
  const DURATION = 15 * 60;
  let end = parseInt(sessionStorage.getItem(KEY) || '0');
  if (!end || end < Date.now() / 1000) {
    end = Math.floor(Date.now() / 1000) + DURATION;
    sessionStorage.setItem(KEY, end);
  }
  function tick() {
    const left = Math.max(0, end - Math.floor(Date.now() / 1000));
    const m = String(Math.floor(left / 60)).padStart(2, '0');
    const s = String(left % 60).padStart(2, '0');
    const el = document.getElementById('timer-display');
    const wrap = document.getElementById('checkout-timer');
    if (el) el.textContent = m + ':' + s;
    if (left <= 60 && wrap) wrap.style.background = '#fee2e2', wrap.style.borderColor = '#ef4444', wrap.style.color = '#991b1b';
    if (left === 0) { sessionStorage.removeItem(KEY); window.location.href = '/'; }
  }
  tick();
  setInterval(tick, 1000);
})();
</script>
<footer style="margin-top:60px">
  <p>&copy; 2026 <strong><%= settings.store_name %></strong></p>
</footer>
</body></html>
