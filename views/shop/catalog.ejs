
<!DOCTYPE html>
<html lang="<%= t.lang %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= t.catalog_title %> - <%= settings.store_name %></title>
  <meta name="description" content="<%= t.catalog_title %> <%= settings.store_name || 'Digihack Store' %> - <%= t.catalog_sub %>">
  <style>:root{--primary:#6c63ff;--primary-dark:#5a52d5;--secondary:#f8f9ff;--accent:#ff6584;--text:#2d3748;--text-light:#718096;--border:#e2e8f0;--white:#fff;--radius:12px;--shadow:0 4px 20px rgba(108,99,255,.12)}*{box-sizing:border-box;margin:0;padding:0}body{font-family:'Inter',-apple-system,sans-serif;background:#f7f8fc;color:var(--text)}a{text-decoration:none;color:inherit}img{max-width:100%}.navbar{background:#fff;box-shadow:0 2px 10px rgba(0,0,0,.08);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}.navbar-brand{font-size:1.4rem;font-weight:800;color:var(--primary)}.navbar-brand span{color:var(--accent)}.navbar-links{display:flex;gap:24px;align-items:center}.navbar-links a{font-size:.9rem;font-weight:500;color:var(--text-light)}.btn-nav{background:var(--primary);color:#fff!important;padding:8px 20px;border-radius:25px;font-weight:600!important}.btn-lang{background:transparent;color:var(--primary)!important;border:1px solid var(--primary);padding:6px 14px;border-radius:20px;font-size:.8rem;font-weight:600!important;cursor:pointer}.section{padding:60px 24px;max-width:1200px;margin:0 auto}.section-title{font-size:1.8rem;font-weight:700;margin-bottom:8px}.section-sub{color:var(--text-light);margin-bottom:32px}.products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:24px}.product-card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;transition:transform .2s,box-shadow .2s;display:flex;flex-direction:column}.product-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(108,99,255,.18)}.card-img{aspect-ratio:1/1;object-fit:cover;width:100%;background:var(--secondary)}.card-img-placeholder{aspect-ratio:1/1;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);display:flex;align-items:center;justify-content:center;font-size:3rem}.card-body{padding:16px;flex:1;display:flex;flex-direction:column}.card-category{font-size:.75rem;text-transform:uppercase;letter-spacing:1px;color:var(--primary);font-weight:600;margin-bottom:6px}.card-title{font-size:1rem;font-weight:700;margin-bottom:8px;color:var(--text);line-height:1.4}.card-desc{font-size:.85rem;color:var(--text-light);margin-bottom:12px;flex:1;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}.card-price{display:flex;align-items:center;gap:8px;margin-bottom:14px}.price-main{font-size:1.2rem;font-weight:800;color:var(--primary)}.price-old{font-size:.85rem;text-decoration:line-through;color:var(--text-light)}.badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px}.badge-new{background:#e0f2fe;color:#0284c7}.badge-hot{background:#fee2e2;color:#dc2626}.badge-sale{background:#fef3c7;color:#d97706}.badge-best{background:#dcfce7;color:#16a34a}.badge-sold-out{background:#f3f4f6;color:#6b7280}.btn-card{width:100%;padding:10px;background:var(--primary);color:#fff;border:none;border-radius:8px;font-weight:600;cursor:pointer;font-size:.9rem}.btn-card-disabled{width:100%;padding:10px;background:#e5e7eb;color:#9ca3af;border:none;border-radius:8px;font-weight:600;font-size:.9rem;cursor:not-allowed}.filter-bar{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:20px;align-items:center}.filter-bar input{flex:1;min-width:200px;padding:10px 16px;border:1px solid var(--border);border-radius:8px;font-size:.9rem;outline:none}.filter-btn{padding:9px 18px;border-radius:8px;border:1px solid var(--border);background:#fff;cursor:pointer;font-size:.85rem;transition:all .2s}.filter-btn.active,.filter-btn:hover{background:var(--primary);color:#fff;border-color:var(--primary)}.category-bar{display:flex;gap:8px;overflow-x:auto;flex-wrap:nowrap;padding-bottom:4px;margin-bottom:20px;scrollbar-width:none;-webkit-overflow-scrolling:touch}.category-bar::-webkit-scrollbar{display:none}.category-bar .filter-btn{white-space:nowrap;flex-shrink:0}.search-btn-row{display:flex;gap:8px}.search-btn-row .filter-btn{flex:1;text-align:center}.sort-select{padding:9px 14px;border-radius:8px;border:1px solid var(--border);background:#fff;font-size:.85rem;color:var(--text);cursor:pointer;outline:none}.price-inputs{display:flex;gap:8px;align-items:center}.price-inputs input{width:120px;padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-size:.85rem;outline:none}.pagination{display:flex;gap:8px;justify-content:center;margin-top:20px}.pagination a{padding:8px 14px;border-radius:8px;background:#fff;box-shadow:var(--shadow);font-size:.85rem;font-weight:600;color:var(--primary)}.pagination a.active{background:var(--primary);color:#fff}footer{background:var(--text);color:#a0aec0;padding:40px 24px;text-align:center;margin-top:60px}footer strong{color:#fff}.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;z-index:200}.hamburger span{display:block;width:24px;height:2.5px;background:var(--text);border-radius:2px;transition:transform .3s,opacity .3s}.hamburger.open span:nth-child(1){transform:translateY(7.5px) rotate(45deg)}.hamburger.open span:nth-child(2){opacity:0}.hamburger.open span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg)}.mobile-menu{display:none}@media(max-width:1024px){.hamburger{display:flex}.navbar-links{display:none!important}.mobile-menu{position:fixed;top:64px;left:0;right:0;background:#fff;z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,.15);border-top:2px solid var(--primary)}.mobile-menu.open{display:block}.mobile-menu a{display:block;padding:15px 20px;font-size:.95rem;font-weight:500;color:#2d3748;border-bottom:1px solid #f0f4f8;text-decoration:none}.mobile-menu a:last-child{border-bottom:none}.section{padding:32px 16px}.products-grid{grid-template-columns:repeat(3,1fr);gap:14px}.filter-bar{gap:8px}.filter-btn{font-size:.82rem;padding:8px 12px}}@media(max-width:640px){.section{padding:20px 14px}.products-grid{grid-template-columns:repeat(2,1fr);gap:10px}.filter-bar{flex-direction:column;align-items:stretch}.filter-bar input{min-width:unset;width:100%}.price-inputs{flex-wrap:wrap;gap:6px}.price-inputs input{flex:1;min-width:80px;width:auto}.sort-select{width:100%}}@media(max-width:400px){.products-grid{grid-template-columns:1fr}}</style>
  <link rel="preload" href="/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/css/style.css"></noscript>
  <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'"><noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
</head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">Digi<span>hack</span></a>
  <div class="navbar-links">
    <a href="/catalog" class="active"><%= t.nav_catalog %></a>
    <a href="/order/status"><%= t.nav_check_order %></a>
    <a href="?lang=<%= t.lang_toggle_url %>" class="btn-lang"><%= t.lang_toggle %></a>
    <a href="/catalog" class="btn-nav"><%= t.nav_shop %></a>
  </div>
  <button class="hamburger" id="hamburger" aria-label="Menu" onclick="toggleMenu()"><span></span><span></span><span></span></button>
</nav>
<div class="mobile-menu" id="mobileMenu">
  <a href="/catalog"><%= t.nav_catalog %></a>
  <a href="/order/status"><%= t.nav_check_order %></a>
  <a href="?lang=<%= t.lang_toggle_url %>"><%= t.lang_toggle %></a>
  <a href="/catalog"><%= t.nav_shop %></a>
</div>

<div class="section">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;margin-bottom:8px">
    <div>
      <h1 class="section-title" style="margin-bottom:4px">📦 <%= t.catalog_title %></h1>
      <p class="section-sub" style="margin-bottom:0"><%= t.catalog_sub %></p>
    </div>
    <a href="/wishlist" id="wishlistNavBtn" style="display:flex;align-items:center;gap:6px;background:#fff;border:1.5px solid var(--border);border-radius:10px;padding:8px 16px;font-size:0.85rem;font-weight:600;color:var(--text);text-decoration:none;transition:all .2s" onmouseover="this.style.borderColor='#e879b0'" onmouseout="this.style.borderColor='var(--border)'">
      ❤️ Wishlist <span id="wishlistCount" style="background:#e879b0;color:white;border-radius:20px;padding:1px 8px;font-size:0.72rem;display:none">0</span>
    </a>
  </div>

  <form method="GET" action="/catalog" class="filter-bar">
    <input type="hidden" name="lang" value="<%= lang %>">
    <input type="text" name="search" placeholder="🔍 <%= t.search_placeholder %>" value="<%= search || '' %>">
    <% if (sort) { %><input type="hidden" name="sort" value="<%= sort %>"><% } %>
    <% if (category) { %><input type="hidden" name="category" value="<%= category %>"><% } %>
    <div class="search-btn-row">
      <button type="submit" class="filter-btn active"><%= t.search_btn %></button>
      <a href="/catalog<%= lang === 'en' ? '?lang=en' : '' %>" class="filter-btn"><%= t.reset %></a>
    </div>
  </form>

  <div class="category-bar">
    <a href="/catalog?<%= search ? 'search='+encodeURIComponent(search)+'&' : '' %><%= lang === 'en' ? 'lang=en&' : '' %>sort=<%= sort || '' %>" class="filter-btn <%= !category ? 'active' : '' %>"><%= t.all %></a>
    <% categories.forEach(c => { %>
    <a href="/catalog?category=<%= encodeURIComponent(c.category) %><%= search ? '&search='+encodeURIComponent(search) : '' %><%= sort ? '&sort='+sort : '' %><%= lang === 'en' ? '&lang=en' : '' %>"
       class="filter-btn <%= category === c.category ? 'active' : '' %>"><%= c.category %></a>
    <% }) %>
  </div>

  <form method="GET" action="/catalog" class="filter-bar" style="margin-bottom:28px">
    <input type="hidden" name="lang" value="<%= lang %>">
    <% if (category) { %><input type="hidden" name="category" value="<%= category %>"><% } %>
    <% if (search) { %><input type="hidden" name="search" value="<%= search %>"><% } %>
    <select name="sort" class="sort-select" onchange="this.form.submit()">
      <option value="" <%= !sort ? 'selected' : '' %>><%= t.sort_label %>: <%= t.sort_newest %></option>
      <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>><%= t.sort_newest %></option>
      <option value="price_asc" <%= sort === 'price_asc' ? 'selected' : '' %>><%= t.sort_price_asc %></option>
      <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>><%= t.sort_price_desc %></option>
      <option value="popular" <%= sort === 'popular' ? 'selected' : '' %>><%= t.sort_popular %></option>
    </select>
    <div class="price-inputs">
      <input type="number" name="min_price" placeholder="<%= t.price_min_placeholder %>" value="<%= min_price || '' %>" min="0">
      <span style="color:var(--text-light)">–</span>
      <input type="number" name="max_price" placeholder="<%= t.price_max_placeholder %>" value="<%= max_price || '' %>" min="0">
      <button type="submit" class="filter-btn active"><%= t.price_filter_btn %></button>
    </div>
  </form>

  <% if(products.length === 0) { %>
  <div style="text-align:center;padding:60px;color:var(--text-light)">
    <div style="font-size:4rem;margin-bottom:16px">💭</div>
    <h3><%= t.not_found_title %></h3>
    <p><%= t.not_found_desc %> <a href="/catalog<%= lang === 'en' ? '?lang=en' : '' %>" style="color:var(--primary)"><%= t.see_all_products %></a></p>
  </div>
  <% } else { %>
  <div class="products-grid">
    <% products.forEach((p, i) => { %>
    <% const isFull = p.max_slots > 0 && (p.sold_slots || 0) >= p.max_slots; %>
    <a href="/product/<%= p.slug %>" class="product-card" style="<%= isFull ? 'opacity:0.75' : '' %>">
      <% if(p.image) { %>
      <img class="card-img" src="<%= p.image %>" alt="<%= p.name %>"<% if(i === 0) { %> fetchpriority="high"<% } else { %> loading="lazy" decoding="async"<% } %>>
      <% } else { %>
      <div class="card-img-placeholder">📦</div>
      <% } %>
      <div class="card-body">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
          <span class="card-category"><%= p.category %></span>
          <div style="display:flex;gap:4px;flex-wrap:wrap;justify-content:flex-end">
            <% if(isFull) { %><span class="badge badge-sold-out"><%= t.slot_full %></span><% } else if(p.badge) { %><span class="badge badge-<%= p.badge.toLowerCase() %>"><%= p.badge %></span><% } %>
          </div>
        </div>
        <div class="card-title"><%= p.name %></div>
        <div class="card-desc"><%= (p.description || '').replace(/<[^>]*>/g, '') %></div>
        <div class="card-price">
          <span class="price-main">Rp <%= (p.discount_price || p.price).toLocaleString('id-ID') %></span>
          <% if(p.discount_price) { %><span class="price-old">Rp <%= p.price.toLocaleString('id-ID') %></span><% } %>
        </div>
        <% if(p.max_slots > 0) { %>
        <div style="font-size:0.75rem;margin-bottom:8px;font-weight:600;color:<%= isFull ? '#9ca3af' : '#16a34a' %>">
          <%= isFull ? '🚫 ' + t.slot_full : '🎟️ ' + t.slot_remaining + ': ' + (p.max_slots - (p.sold_slots||0)) + '/' + p.max_slots %>
        </div>
        <% } else if(p.total_sold > 0) { %>
        <div style="font-size:0.75rem;color:#16a34a;font-weight:600;margin-bottom:8px">🔥 <%= p.total_sold %> <%= t.sold %></div>
        <% } %>
        <div style="display:flex;gap:8px">
          <% if(isFull) { %>
          <button class="btn-card-disabled" disabled style="flex:1"><%= t.slot_full %></button>
          <% } else { %>
          <button class="btn-card" style="flex:1"><%= t.buy_now %></button>
          <% } %>
          <button class="btn-wishlist" onclick="event.preventDefault();toggleWishlist('<%= p.id %>','<%= p.name.replace(/'/g,"\\'") %>','<%= p.image || '' %>',<%= p.discount_price || p.price %>,'<%= p.slug %>')" id="wl-<%= p.id %>" style="width:40px;border:1.5px solid var(--border);border-radius:8px;background:#fff;cursor:pointer;font-size:1.1rem;transition:all .2s;padding:0">🤍</button>
        </div>
      </div>
    </a>
    <% }) %>
  </div>

  <% const totalPages = Math.ceil(total/limit); if(totalPages > 1) { %>
  <div class="pagination">
    <% for(let i=1;i<=totalPages;i++) { %>
    <a href="/catalog?page=<%= i %><%= category ? '&category='+encodeURIComponent(category) : '' %><%= search ? '&search='+encodeURIComponent(search) : '' %><%= sort ? '&sort='+sort : '' %><%= min_price ? '&min_price='+min_price : '' %><%= max_price ? '&max_price='+max_price : '' %><%= lang === 'en' ? '&lang=en' : '' %>"
       class="<%= i === page ? 'active' : '' %>"><%= i %></a>
    <% } %>
  </div>
  <% } %>
  <% } %>
</div>

<footer>
  <p>&copy; 2026 <strong><%= settings.store_name %></strong>. <%= t.footer_rights %></p>
</footer>
<script>
function toggleMenu(){const h=document.getElementById('hamburger'),m=document.getElementById('mobileMenu');h.classList.toggle('open');m.classList.toggle('open');}
document.addEventListener('click',function(e){const h=document.getElementById('hamburger'),m=document.getElementById('mobileMenu');if(h&&m&&!h.contains(e.target)&&!m.contains(e.target)){h.classList.remove('open');m.classList.remove('open');}});
window.addEventListener('scroll',function(){const h=document.getElementById('hamburger'),m=document.getElementById('mobileMenu');if(h)h.classList.remove('open');if(m)m.classList.remove('open');},{passive:true});
function getWishlist() { try { return JSON.parse(localStorage.getItem('dg_wishlist') || '[]'); } catch(e) { return []; } }
function saveWishlist(wl) { localStorage.setItem('dg_wishlist', JSON.stringify(wl)); }
function updateWishlistUI() {
  const wl = getWishlist();
  const cnt = document.getElementById('wishlistCount');
  if (cnt) { if (wl.length > 0) { cnt.textContent = wl.length; cnt.style.display='inline'; } else { cnt.style.display='none'; } }
  wl.forEach(item => {
    const btn = document.getElementById('wl-' + item.id);
    if (btn) btn.textContent = '❤️';
  });
}
function toggleWishlist(id, name, image, price, slug) {
  let wl = getWishlist();
  const idx = wl.findIndex(x => x.id == id);
  const btn = document.getElementById('wl-' + id);
  if (idx >= 0) { wl.splice(idx, 1); if (btn) btn.textContent = '🤍'; }
  else { wl.push({ id, name, image, price, slug }); if (btn) btn.textContent = '❤️'; }
  saveWishlist(wl);
  updateWishlistUI();
}
updateWishlistUI();
</script>
<% if(settings.meta_pixel_id) { %>
<script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= settings.meta_pixel_id %>');fbq('track','PageView');</script>
<% } %>
<% if(settings && settings.ga4_id) { %><script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.ga4_id %>"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","<%= settings.ga4_id %>");</script><% } %>
</body></html>
