
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Catalog - <%= settings.store_name %></title>
  <meta name="description" content="Catalog produk digital <%= settings.store_name || 'Digihack Store' %> - Temukan semua produk digital berkualitas dengan harga terbaik.">
  <style>:root{--primary:#6c63ff;--primary-dark:#5a52d5;--secondary:#f8f9ff;--accent:#ff6584;--text:#2d3748;--text-light:#718096;--border:#e2e8f0;--white:#fff;--radius:12px;--shadow:0 4px 20px rgba(108,99,255,.12)}*{box-sizing:border-box;margin:0;padding:0}body{font-family:'Inter',-apple-system,sans-serif;background:#f7f8fc;color:var(--text)}a{text-decoration:none;color:inherit}img{max-width:100%}.navbar{background:#fff;box-shadow:0 2px 10px rgba(0,0,0,.08);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}.navbar-brand{font-size:1.4rem;font-weight:800;color:var(--primary)}.navbar-brand span{color:var(--accent)}.navbar-links{display:flex;gap:24px;align-items:center}.navbar-links a{font-size:.9rem;font-weight:500;color:var(--text-light)}.btn-nav{background:var(--primary);color:#fff!important;padding:8px 20px;border-radius:25px;font-weight:600!important}.section{padding:60px 24px;max-width:1200px;margin:0 auto}.section-title{font-size:1.8rem;font-weight:700;margin-bottom:8px}.section-sub{color:var(--text-light);margin-bottom:32px}.products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:24px}.product-card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;transition:transform .2s,box-shadow .2s;display:flex;flex-direction:column}.product-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(108,99,255,.18)}.card-img{aspect-ratio:1/1;object-fit:cover;width:100%;background:var(--secondary)}.card-img-placeholder{aspect-ratio:1/1;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);display:flex;align-items:center;justify-content:center;font-size:3rem}.card-body{padding:16px;flex:1;display:flex;flex-direction:column}.card-category{font-size:.75rem;text-transform:uppercase;letter-spacing:1px;color:var(--primary);font-weight:600;margin-bottom:6px}.card-title{font-size:1rem;font-weight:700;margin-bottom:8px;color:var(--text);line-height:1.4}.card-desc{font-size:.85rem;color:var(--text-light);margin-bottom:12px;flex:1;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}.card-price{display:flex;align-items:center;gap:8px;margin-bottom:14px}.price-main{font-size:1.2rem;font-weight:800;color:var(--primary)}.price-old{font-size:.85rem;text-decoration:line-through;color:var(--text-light)}.badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px}.badge-new{background:#e0f2fe;color:#0284c7}.badge-hot{background:#fee2e2;color:#dc2626}.badge-sale{background:#fef3c7;color:#d97706}.badge-best{background:#dcfce7;color:#16a34a}.btn-card{width:100%;padding:10px;background:var(--primary);color:#fff;border:none;border-radius:8px;font-weight:600;cursor:pointer;font-size:.9rem}.filter-bar{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:28px;align-items:center}.filter-bar input{flex:1;min-width:200px;padding:10px 16px;border:1px solid var(--border);border-radius:8px;font-size:.9rem;outline:none}.filter-btn{padding:9px 18px;border-radius:8px;border:1px solid var(--border);background:#fff;cursor:pointer;font-size:.85rem;transition:all .2s}.filter-btn.active,.filter-btn:hover{background:var(--primary);color:#fff;border-color:var(--primary)}.pagination{display:flex;gap:8px;justify-content:center;margin-top:20px}.pagination a{padding:8px 14px;border-radius:8px;background:#fff;box-shadow:var(--shadow);font-size:.85rem;font-weight:600;color:var(--primary)}.pagination a.active{background:var(--primary);color:#fff}footer{background:var(--text);color:#a0aec0;padding:40px 24px;text-align:center;margin-top:60px}footer strong{color:#fff}</style>
  <link rel="preload" href="/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/css/style.css"></noscript>
  <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'"><noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
</head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">Digi<span>hack</span></a>
  <div class="navbar-links">
    <a href="/catalog" class="active">Catalog</a>
    <a href="/order/status">Cek Order</a>
    <a href="/catalog" class="btn-nav">Belanja Sekarang</a>
  </div>
</nav>

<div class="section">
  <h1 class="section-title">📦 Catalog Produk</h1>
  <p class="section-sub">Temukan produk digital impian kamu</p>

  <form method="GET" action="/catalog" class="filter-bar">
    <input type="text" name="search" placeholder="🔍 Cari produk..." value="<%= search || '' %>">
    <button type="submit" class="filter-btn active">Cari</button>
    <a href="/catalog" class="filter-btn">Reset</a>
  </form>

  <div class="filter-bar">
    <a href="/catalog" class="filter-btn <%= !category ? 'active' : '' %>">Semua</a>
    <% categories.forEach(c => { %>
    <a href="/catalog?category=<%= encodeURIComponent(c.category) %><%= search ? '&search='+encodeURIComponent(search) : '' %>"
       class="filter-btn <%= category === c.category ? 'active' : '' %>"><%= c.category %></a>
    <% }) %>
  </div>

  <% if(products.length === 0) { %>
  <div style="text-align:center;padding:60px;color:var(--text-light)">
    <div style="font-size:4rem;margin-bottom:16px">💭</div>
    <h3>Produk tidak ditemukan</h3>
    <p>Coba kata kunci lain atau <a href="/catalog" style="color:var(--primary)">lihat semua produk</a></p>
  </div>
  <% } else { %>
  <div class="products-grid">
    <% products.forEach((p, i) => { %>
    <a href="/product/<%= p.slug %>" class="product-card">
      <% if(p.image) { %>
      <img class="card-img" src="<%= p.image %>" alt="<%= p.name %>"<% if(i === 0) { %> fetchpriority="high"<% } else { %> loading="lazy" decoding="async"<% } %>>
      <% } else { %>
      <div class="card-img-placeholder">📦</div>
      <% } %>
      <div class="card-body">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
          <span class="card-category"><%= p.category %></span>
          <% if(p.badge) { %><span class="badge badge-<%= p.badge.toLowerCase() %>"><%= p.badge %></span><% } %>
        </div>
        <div class="card-title"><%= p.name %></div>
        <div class="card-desc"><%= (p.description || '').replace(/<[^>]*>/g, '') %></div>
        <div class="card-price">
          <span class="price-main">Rp <%= (p.discount_price || p.price).toLocaleString('id-ID') %></span>
          <% if(p.discount_price) { %><span class="price-old">Rp <%= p.price.toLocaleString('id-ID') %></span><% } %>
        </div>
        <% if(p.total_sold > 0) { %>
        <div style="font-size:0.75rem;color:#16a34a;font-weight:600;margin-bottom:8px">🔥 <%= p.total_sold %> terjual</div>
        <% } %>
        <button class="btn-card">Beli Sekarang</button>
      </div>
    </a>
    <% }) %>
  </div>

  <% const totalPages = Math.ceil(total/limit); if(totalPages > 1) { %>
  <div class="pagination">
    <% for(let i=1;i<=totalPages;i++) { %>
    <a href="/catalog?page=<%= i %><%= category ? '&category='+encodeURIComponent(category) : '' %><%= search ? '&search='+encodeURIComponent(search) : '' %>"
       class="<%= i === page ? 'active' : '' %>"><%= i %></a>
    <% } %>
  </div>
  <% } %>
  <% } %>
</div>

<footer>
  <p>&copy; 2026 <strong><%= settings.store_name %></strong>. All rights reserved.</p>
</footer>
<% if(settings.meta_pixel_id) { %>
<script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= settings.meta_pixel_id %>');fbq('track','PageView');</script>
<% } %>
<% if(settings && settings.ga4_id) { %><script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.ga4_id %>"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","<%= settings.ga4_id %>");</script><% } %>
</body></html>
