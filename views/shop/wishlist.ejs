<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Wishlist - <%= settings.store_name %></title>
  <style>:root{--primary:#6c63ff;--accent:#ff6584;--text:#2d3748;--text-light:#718096;--border:#e2e8f0;--radius:12px;--shadow:0 4px 20px rgba(108,99,255,.12)}*{box-sizing:border-box;margin:0;padding:0}body{font-family:'Inter',-apple-system,sans-serif;background:#f7f8fc;color:var(--text)}a{text-decoration:none;color:inherit}.navbar{background:#fff;box-shadow:0 2px 10px rgba(0,0,0,.08);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}.navbar-brand{font-size:1.4rem;font-weight:800;color:var(--primary)}.navbar-brand span{color:var(--accent)}.navbar-links{display:flex;gap:20px;align-items:center}.navbar-links a{font-size:.9rem;font-weight:500;color:var(--text-light)}.btn-nav{background:var(--primary);color:#fff!important;padding:8px 20px;border-radius:25px;font-weight:600!important}.wrap{max-width:900px;margin:40px auto;padding:0 20px}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:20px}.card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;transition:transform .2s}.card:hover{transform:translateY(-3px)}.card img{width:100%;aspect-ratio:1/1;object-fit:cover}.card-placeholder{width:100%;aspect-ratio:1/1;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);display:flex;align-items:center;justify-content:center;font-size:3rem}.card-body{padding:14px}.card-name{font-weight:700;font-size:.92rem;margin-bottom:6px;line-height:1.35}.card-price{color:var(--primary);font-weight:800;font-size:1rem;margin-bottom:10px}.card-actions{display:flex;gap:8px}.btn-buy{flex:1;padding:9px;background:var(--primary);color:#fff;border:none;border-radius:8px;font-weight:600;cursor:pointer;font-size:.85rem}.btn-remove{width:36px;border:1.5px solid var(--border);background:#fff;border-radius:8px;cursor:pointer;font-size:1rem;transition:border-color .2s}.btn-remove:hover{border-color:#fc8181}.empty{text-align:center;padding:80px 20px;color:var(--text-light)}.empty-icon{font-size:4rem;margin-bottom:16px}.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;z-index:200}.hamburger span{display:block;width:24px;height:2.5px;background:var(--text);border-radius:2px;transition:transform .3s,opacity .3s}.hamburger.open span:nth-child(1){transform:translateY(7.5px) rotate(45deg)}.hamburger.open span:nth-child(2){opacity:0}.hamburger.open span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg)}@media(max-width:768px){.hamburger{display:flex}.navbar{position:relative}.navbar-links{display:none;position:absolute;top:64px;left:0;right:0;background:#fff;flex-direction:column;padding:8px 0;box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:99}.navbar-links.open{display:flex}.navbar-links a{padding:14px 24px;font-size:.95rem;border-bottom:1px solid #f0f4f8;color:var(--text)}.navbar-links a:last-child{border-bottom:none}.btn-nav{margin:8px 24px 14px;border-radius:8px;text-align:center;display:block;padding:12px}.wrap{padding:0 16px}.grid{grid-template-columns:repeat(2,1fr);gap:12px}}@media(max-width:400px){.grid{grid-template-columns:1fr}}</style>
  <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'"><noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
</head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">Digi<span>hack</span></a>
  <button class="hamburger" id="hamburger" aria-label="Menu" onclick="toggleMenu()"><span></span><span></span><span></span></button>
  <div class="navbar-links" id="navLinks">
    <a href="/catalog">Catalog</a>
    <a href="/order/status">Cek Order</a>
    <a href="/catalog" class="btn-nav">Belanja</a>
  </div>
</nav>

<div class="wrap">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:10px">
    <div>
      <h1 style="font-size:1.6rem;font-weight:800;margin-bottom:4px">❤️ Wishlist Kamu</h1>
      <p style="color:var(--text-light);font-size:0.9rem" id="wishlistSubtitle">Loading...</p>
    </div>
    <button onclick="clearAll()" style="padding:8px 16px;border:1.5px solid var(--border);background:#fff;border-radius:8px;font-size:0.82rem;cursor:pointer;color:var(--text-light)" id="clearBtn">🗑️ Hapus Semua</button>
  </div>

  <div id="wishlistGrid" class="grid"></div>
  <div id="emptyState" class="empty" style="display:none">
    <div class="empty-icon">💭</div>
    <h3 style="font-size:1.2rem;margin-bottom:8px">Wishlist kamu masih kosong</h3>
    <p style="margin-bottom:20px">Tambahkan produk favorit kamu dari halaman catalog!</p>
    <a href="/catalog" style="display:inline-block;background:var(--primary);color:#fff;padding:12px 28px;border-radius:10px;font-weight:700">Lihat Catalog →</a>
  </div>
</div>

<footer style="background:#2d3748;color:#a0aec0;padding:30px 24px;text-align:center;margin-top:60px">
  <p>&copy; 2026 <strong style="color:#fff"><%= settings.store_name %></strong></p>
</footer>

<script>
function toggleMenu(){const h=document.getElementById('hamburger'),n=document.getElementById('navLinks');h.classList.toggle('open');n.classList.toggle('open');}
document.addEventListener('click',function(e){const h=document.getElementById('hamburger'),n=document.getElementById('navLinks');if(h&&n&&!h.contains(e.target)&&!n.contains(e.target)){h.classList.remove('open');n.classList.remove('open');}});
function getWishlist() { try { return JSON.parse(localStorage.getItem('dg_wishlist')||'[]'); } catch(e) { return []; } }
function saveWishlist(wl) { localStorage.setItem('dg_wishlist', JSON.stringify(wl)); }

function removeItem(id) {
  let wl = getWishlist().filter(x => x.id != id);
  saveWishlist(wl);
  render();
}

function clearAll() {
  if (!confirm('Hapus semua item dari wishlist?')) return;
  saveWishlist([]);
  render();
}

function render() {
  const wl = getWishlist();
  const grid = document.getElementById('wishlistGrid');
  const empty = document.getElementById('emptyState');
  const sub = document.getElementById('wishlistSubtitle');
  const clearBtn = document.getElementById('clearBtn');

  sub.textContent = wl.length + ' produk tersimpan';
  clearBtn.style.display = wl.length ? 'block' : 'none';

  if (!wl.length) {
    grid.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';
  grid.innerHTML = wl.map(p => `
    <div class="card">
      ${p.image ? `<img src="${p.image}" alt="${p.name}">` : '<div class="card-placeholder">📦</div>'}
      <div class="card-body">
        <div class="card-name">${p.name}</div>
        <div class="card-price">Rp ${Number(p.price).toLocaleString('id-ID')}</div>
        <div class="card-actions">
          <a href="/product/${p.slug}" style="flex:1"><button class="btn-buy" style="width:100%">Beli Sekarang</button></a>
          <button class="btn-remove" onclick="removeItem('${p.id}')">🗑️</button>
        </div>
      </div>
    </div>
  `).join('');
}

render();
</script>
</body>
</html>
