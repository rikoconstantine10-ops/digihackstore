
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Status Order - <%= settings.store_name %></title>
  <style>:root{--primary:#6c63ff;--primary-dark:#5a52d5;--secondary:#f8f9ff;--text:#2d3748;--text-light:#718096;--border:#e2e8f0;--white:#fff;--radius:12px;--shadow:0 4px 20px rgba(108,99,255,.12);--success:#48bb78;--warning:#f6ad55;--danger:#fc8181}*{box-sizing:border-box;margin:0;padding:0}body{font-family:'Inter',-apple-system,sans-serif;background:#f7f8fc;color:var(--text)}a{text-decoration:none;color:inherit}.navbar{background:#fff;box-shadow:0 2px 10px rgba(0,0,0,.08);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}.navbar-brand{font-size:1.4rem;font-weight:800;color:var(--primary)}.navbar-brand span{color:#ff6584}.navbar-links{display:flex;gap:24px;align-items:center}.navbar-links a{font-size:.9rem;font-weight:500;color:var(--text-light)}.status-wrap{max-width:520px;margin:60px auto;padding:0 16px;text-align:center}.status-icon{font-size:5rem;margin-bottom:16px}.status-card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow);padding:32px}.status-success{color:var(--success)}.status-pending{color:var(--warning)}.status-expired{color:var(--danger)}.order-detail-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);font-size:.9rem}.form-group{margin-bottom:16px}.form-group label{display:block;font-size:.85rem;font-weight:600;margin-bottom:6px}.form-group input{width:100%;padding:11px 14px;border:1px solid var(--border);border-radius:8px;font-size:.95rem;outline:none}.btn-submit{width:100%;padding:15px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border:none;border-radius:12px;font-size:1rem;font-weight:700;cursor:pointer}footer{background:var(--text);color:#a0aec0;padding:40px 24px;text-align:center;margin-top:60px}footer strong{color:#fff}.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;z-index:200}.hamburger span{display:block;width:24px;height:2.5px;background:var(--text);border-radius:2px;transition:transform .3s,opacity .3s}.hamburger.open span:nth-child(1){transform:translateY(7.5px) rotate(45deg)}.hamburger.open span:nth-child(2){opacity:0}.hamburger.open span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg)}@media(max-width:768px){.hamburger{display:flex}.navbar{position:relative}.navbar-links{display:none;position:absolute;top:64px;left:0;right:0;background:#fff;flex-direction:column;padding:8px 0;box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:99}.navbar-links.open{display:flex}.navbar-links a{padding:14px 24px;font-size:.95rem;border-bottom:1px solid #f0f4f8;color:var(--text)}.navbar-links a:last-child{border-bottom:none}.status-wrap{margin:24px auto}.status-card{padding:20px}}</style>
  <link rel="preload" href="/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/css/style.css"></noscript>
  <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'"><noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
<% if(settings && settings.ga4_id) { %><script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.ga4_id %>"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","<%= settings.ga4_id %>");</script><% } %></head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">Digi<span>hack</span></a>
  <button class="hamburger" id="hamburger" aria-label="Menu" onclick="toggleMenu()"><span></span><span></span><span></span></button>
  <div class="navbar-links" id="navLinks"><a href="/catalog">Catalog</a><a href="/order/status">Cek Order</a></div>
</nav>

<div class="status-wrap">
  <% if(!order) { %>
  <div class="status-card">
    <div class="status-icon">🔍</div>
    <h2 style="font-size:1.4rem;font-weight:800;margin-bottom:8px">Cek Status Order</h2>
    <p style="color:var(--text-light);margin-bottom:24px;font-size:0.9rem">Masukkan nomor order kamu</p>
    <form method="GET" action="/order/status">
      <div class="form-group"><label>Nomor Order / Ref</label><input type="text" name="ref" placeholder="Contoh: 12345678" required></div>
      <button type="submit" class="btn-submit">🔍 Cek Sekarang</button>
    </form>
  </div>
  <% } else if(order.status === 'success') { %>
  <div class="status-icon">✅</div>
  <div class="status-card">
    <h2 class="status-success" style="font-size:1.4rem;font-weight:800;margin-bottom:20px">🎉 Pembayaran Berhasil!</h2>
    <div class="order-detail-row"><span>Order ID</span><strong>#<%= order.ref_kode %></strong></div>
    <div class="order-detail-row"><span>Produk</span><strong><%= order.product_name %></strong></div>
    <div class="order-detail-row"><span>Nama</span><strong><%= order.customer_name %></strong></div>
    <div class="order-detail-row"><span>Email</span><strong><%= order.customer_email %></strong></div>
    <div class="order-detail-row"><span>Total</span><strong style="color:var(--primary)">Rp <%= order.amount.toLocaleString('id-ID') %></strong></div>
    <div class="order-detail-row"><span>Dibayar</span><strong><%= order.paid_at %></strong></div>
    <% if(product && product.product_link) { %>
    <div style="text-align:center;margin:24px 0">
      <a href="<%= product.product_link %>" target="_blank" rel="noopener" style="display:inline-block;background:linear-gradient(135deg,#667eea,#764ba2);color:white;padding:16px 36px;border-radius:10px;text-decoration:none;font-weight:700;font-size:1.05rem">
        ⬇️ Download Produk Sekarang
      </a>
      <div style="margin-top:10px;font-size:0.8rem;color:var(--text-light)">Link juga sudah dikirim ke email kamu</div>
    </div>
    <% } else { %>
    <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:16px;margin-top:20px;text-align:center;font-size:0.9rem;color:#166534">
      📧 Produk sudah dikirim ke email <strong><%= order.customer_email %></strong><br>Cek inbox atau folder spam.
    </div>
    <% } %>
    <a href="/catalog" style="display:block;text-align:center;margin-top:20px;color:var(--primary);font-weight:600">Belanja lagi →</a>
  </div>

  <% if(typeof upsells !== 'undefined' && upsells.length > 0) { %>
  <div style="margin-top:24px">
    <div style="font-size:0.82rem;font-weight:700;color:var(--text-light);text-align:center;margin-bottom:12px;text-transform:uppercase;letter-spacing:1px">✨ Produk yang mungkin kamu suka</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px">
      <% upsells.forEach(u => { %>
      <a href="/product/<%= u.slug %>" style="background:#fff;border-radius:10px;overflow:hidden;box-shadow:0 2px 10px rgba(108,99,255,.1);display:block;text-decoration:none;color:inherit;transition:transform .2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
        <% if(u.image) { %><img src="<%= u.image %>" alt="<%= u.name %>" style="width:100%;aspect-ratio:1/1;object-fit:cover">
        <% } else { %><div style="width:100%;aspect-ratio:1/1;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);display:flex;align-items:center;justify-content:center;font-size:2rem">📦</div><% } %>
        <div style="padding:10px">
          <div style="font-size:0.8rem;font-weight:700;margin-bottom:4px;line-height:1.3"><%= u.name %></div>
          <div style="font-size:0.85rem;font-weight:800;color:var(--primary)">Rp <%= (u.discount_price||u.price).toLocaleString('id-ID') %></div>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <% } else if(order.status === 'pending') { %>
  <div class="status-icon">⏳</div>
  <div class="status-card">
    <h2 class="status-pending" style="font-size:1.4rem;font-weight:800;margin-bottom:20px">Menunggu Pembayaran</h2>
    <div class="order-detail-row"><span>Order ID</span><strong>#<%= order.ref_kode %></strong></div>
    <div class="order-detail-row"><span>Produk</span><strong><%= order.product_name %></strong></div>
    <div class="order-detail-row"><span>Total</span><strong style="color:var(--warning)">Rp <%= order.amount.toLocaleString('id-ID') %></strong></div>
    <% if(order.checkout_url) { %>
    <a href="<%= order.checkout_url %>" style="display:block;margin-top:20px">
      <button class="btn-submit">💳 Lanjutkan Pembayaran</button>
    </a>
    <% } %>
  </div>
  <% } else { %>
  <div class="status-icon">❌</div>
  <div class="status-card">
    <h2 class="status-expired" style="font-size:1.4rem;font-weight:800;margin-bottom:20px">Order Expired / Refund</h2>
    <div class="order-detail-row"><span>Order ID</span><strong>#<%= order.ref_kode %></strong></div>
    <div class="order-detail-row"><span>Status</span><strong><%= order.status %></strong></div>
    <a href="/catalog" style="display:block;text-align:center;margin-top:20px;color:var(--primary);font-weight:600">Order ulang →</a>
  </div>
  <% } %>
</div>

<footer style="margin-top:60px">
  <p>&copy; 2026 <strong><%= settings.store_name %></strong></p>
</footer>
<script>
function toggleMenu(){const h=document.getElementById('hamburger'),n=document.getElementById('navLinks');h.classList.toggle('open');n.classList.toggle('open');}
document.addEventListener('click',function(e){const h=document.getElementById('hamburger'),n=document.getElementById('navLinks');if(h&&n&&!h.contains(e.target)&&!n.contains(e.target)){h.classList.remove('open');n.classList.remove('open');}});
</script>
<% if (typeof settings !== 'undefined' && settings.meta_pixel_id) { %>
<script>
!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
fbq('init', '<%= settings.meta_pixel_id %>');
fbq('track', 'PageView');
<% if (typeof order !== 'undefined' && order && order.status === 'success') { %>
// Guard: only fire Purchase once per session (prevent re-fire on page refresh)
var purchaseKey = 'px_purchase_<%= order.ref_kode %>';
if (!sessionStorage.getItem(purchaseKey)) {
  sessionStorage.setItem(purchaseKey, '1');
  fbq('track', 'Purchase',
    { value: <%= order.amount %>, currency: 'IDR', content_name: '<%= (order.product_name||"").replace(/'/g,"\\'") %>', content_ids: ['<%= order.product_id %>'], content_type: 'product', order_id: '<%= order.ref_kode %>' },
    { eventID: 'purchase_<%= order.ref_kode %>' }
  );
}
<% } %>
</script>
<noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=<%= settings.meta_pixel_id %>&ev=PageView&noscript=1"/></noscript>
<% } %>
</body></html>
