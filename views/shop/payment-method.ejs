<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Pilih Pembayaran - <%= settings.store_name || 'Digihack Store' %></title>
  <style>:root{--primary:#6c63ff;--primary-dark:#5a52d5;--secondary:#f8f9ff;--text:#2d3748;--text-light:#718096;--border:#e2e8f0;--white:#fff;--radius:12px;--shadow:0 4px 20px rgba(108,99,255,.12)}*{box-sizing:border-box;margin:0;padding:0}body{font-family:'Inter',-apple-system,sans-serif;background:#f7f8fc;color:var(--text)}a{text-decoration:none;color:inherit}img{max-width:100%}.navbar{background:#fff;box-shadow:0 2px 10px rgba(0,0,0,.08);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}.navbar-brand{font-size:1.4rem;font-weight:800;color:var(--primary)}.navbar-brand span{color:#ff6584}.navbar-links{display:flex;gap:24px;align-items:center}.navbar-links a{font-size:.9rem;font-weight:500;color:var(--text-light)}.checkout-wrap{max-width:480px;margin:40px auto;padding:0 16px}.checkout-card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow);padding:32px}.checkout-product{background:var(--secondary);border-radius:8px;padding:16px;margin-bottom:24px;display:flex;gap:12px;align-items:center}.checkout-product img{width:60px;height:60px;object-fit:cover;border-radius:8px}.checkout-product .name{font-weight:700;font-size:.95rem}.btn-submit{width:100%;padding:15px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border:none;border-radius:12px;font-size:1rem;font-weight:700;cursor:pointer}.error-msg{background:#fee2e2;color:#dc2626;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:.9rem}footer{background:var(--text);color:#a0aec0;padding:40px 24px;text-align:center;margin-top:60px}footer strong{color:#fff}</style>
  <link rel="preload" href="/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/css/style.css"></noscript>
  <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'"><noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
  <% if(settings && settings.meta_pixel_id) { %><script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= settings.meta_pixel_id %>');fbq('track','PageView');fbq('track','AddPaymentInfo',{content_ids:['<%= product.id %>'],content_type:'product',content_name:'<%= (pending.productName||product.name).replace(/'/g,"\\'") %>',value:<%= pending.amount || (product.discount_price || product.price) %>,currency:'IDR'},<% if(typeof apEventId !== "undefined" && apEventId) { %>{eventID:'<%= apEventId %>'}<% } else { %>{}<% } %>);</script><% } %>
  <% if(settings && settings.ga4_id) { %><script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.ga4_id %>"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","<%= settings.ga4_id %>");</script><% } %>
  <style>
    .pm-accordion { border: 1.5px solid var(--border); border-radius: 10px; margin-bottom: 10px; overflow: hidden; }
    .pm-accordion-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 13px 16px; cursor: pointer; background: #fff;
      font-size: 0.88rem; font-weight: 700; color: var(--text);
      user-select: none; transition: background 0.15s;
    }
    .pm-accordion-header:hover { background: #fafafa; }
    .pm-accordion-header.open { background: #f5f3ff; border-bottom: 1.5px solid var(--border); }
    .pm-accordion-header .pm-acc-left { display: flex; align-items: center; gap: 10px; }
    .pm-accordion-header .chevron { width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; transition: transform 0.2s; color: var(--text-light); }
    .pm-accordion-header.open .chevron { transform: rotate(180deg); }
    .pm-accordion-body { display: none; padding: 12px; background: #fafbff; }
    .pm-accordion-body.open { display: block; }
    .pm-selected-badge { font-size: 0.7rem; font-weight: 600; background: var(--primary); color: #fff; border-radius: 20px; padding: 2px 8px; }
    .payment-methods { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
    @media (max-width: 400px) { .payment-methods { grid-template-columns: repeat(2, 1fr); } }
    .payment-option { position: relative; cursor: pointer; }
    .payment-option input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
    .pm-card {
      border: 2px solid var(--border); border-radius: 8px;
      padding: 10px 6px 8px; text-align: center;
      transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
      background: #fff; display: flex; flex-direction: column;
      align-items: center; gap: 5px; min-height: 72px; justify-content: center;
    }
    .payment-option input:checked + .pm-card { border-color: var(--primary); background: #f5f3ff; box-shadow: 0 2px 8px rgba(102,126,234,0.2); }
    .payment-option:hover .pm-card { border-color: #a5b4fc; }
    .pm-logo { height: 26px; max-width: 68px; object-fit: contain; display: block; }
    .pm-name { font-size: 0.72rem; font-weight: 700; color: var(--text); line-height: 1.2; }
  </style>
</head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">Digi<span>hack</span></a>
  <div class="navbar-links"><a href="/catalog">Catalog</a></div>
</nav>

<div class="checkout-wrap">
  <div style="text-align:center;margin:32px 0 24px">
    <div style="font-size:2rem;margin-bottom:8px">💳</div>
    <h1 style="font-size:1.5rem;font-weight:800">Metode Pembayaran</h1>
    <p style="color:var(--text-light);font-size:0.9rem">Pilih metode pembayaran yang kamu inginkan</p>
    <div id="checkout-timer" style="display:inline-flex;align-items:center;gap:6px;background:#fff3cd;border:1px solid #ffc107;border-radius:20px;padding:5px 14px;font-size:0.8rem;font-weight:700;color:#856404;margin-top:8px">
      ⏱ Sesi berakhir dalam <span id="timer-display">15:00</span>
    </div>
  </div>

  <!-- Step indicator -->
  <div style="display:flex;justify-content:center;align-items:center;gap:0;margin-bottom:28px">
    <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
      <div style="width:32px;height:32px;border-radius:50%;background:#10b981;color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.9rem;font-weight:700">✓</div>
      <span style="font-size:0.7rem;font-weight:600;color:#10b981">Data Diri</span>
    </div>
    <div style="width:48px;height:2px;background:#10b981;margin-bottom:20px"></div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
      <div style="width:32px;height:32px;border-radius:50%;background:#10b981;color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.9rem;font-weight:700">✓</div>
      <span style="font-size:0.7rem;font-weight:600;color:#10b981">Add-on</span>
    </div>
    <div style="width:48px;height:2px;background:#e2e8f0;margin-bottom:20px"></div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
      <div style="width:32px;height:32px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700">3</div>
      <span style="font-size:0.7rem;font-weight:600;color:var(--primary)">Pembayaran</span>
    </div>
  </div>

  <div class="checkout-card">
    <!-- Order summary -->
    <div class="checkout-product">
      <% if(product.image) { %>
      <img src="<%= product.image %>" alt="<%= product.name %>">
      <% } else { %>
      <div style="width:60px;height:60px;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.5rem">📦</div>
      <% } %>
      <div style="flex:1">
        <div class="name"><%= pending.productName %><% if(pending.addonProductName) { %> + <%= pending.addonProductName %><% } %></div>
        <div style="font-size:0.8rem;color:var(--text-light);margin-top:2px">untuk: <%= pending.name %></div>
      </div>
    </div>

    <% if(typeof error !== 'undefined' && error) { %><div class="error-msg">❌ <%= error %></div><% } %>

    <form method="POST" action="/checkout/<%= product.slug %>/payment">

      <!-- QRIS -->
      <div class="pm-accordion" id="acc-qris">
        <div class="pm-accordion-header" onclick="toggleAcc('qris')">
          <div class="pm-acc-left">
            <span style="font-size:1.1rem">📱</span>
            <span>QRIS</span>
            <span class="pm-selected-badge" id="badge-qris" style="display:none"></span>
          </div>
          <div class="chevron"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></div>
        </div>
        <div class="pm-accordion-body" id="body-qris">
          <div class="payment-methods">
            <label class="payment-option">
              <input type="radio" name="channel" value="QRIS" required data-group="qris" data-label="QRIS">
              <div class="pm-card">
                <img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/qris.png" alt="QRIS">
                <div class="pm-name">QRIS</div>
              </div>
            </label>
          </div>
        </div>
      </div>

      <!-- E-Wallet -->
      <div class="pm-accordion" id="acc-ewallet">
        <div class="pm-accordion-header" onclick="toggleAcc('ewallet')">
          <div class="pm-acc-left">
            <span style="font-size:1.1rem">💳</span>
            <span>E-Wallet</span>
            <span class="pm-selected-badge" id="badge-ewallet" style="display:none"></span>
          </div>
          <div class="chevron"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></div>
        </div>
        <div class="pm-accordion-body" id="body-ewallet">
          <div class="payment-methods">
            <label class="payment-option">
              <input type="radio" name="channel" value="DANA" data-group="ewallet" data-label="DANA">
              <div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/dana.webp" alt="DANA"><div class="pm-name">DANA</div></div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="OVO" data-group="ewallet" data-label="OVO">
              <div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/ovo.webp" alt="OVO"><div class="pm-name">OVO</div></div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="Shopee Pay" data-group="ewallet" data-label="ShopeePay">
              <div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/logo-shopeepay.png" alt="ShopeePay"><div class="pm-name">ShopeePay</div></div>
            </label>
            <label class="payment-option">
              <input type="radio" name="channel" value="Link Aja" data-group="ewallet" data-label="LinkAja">
              <div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/link-aja.png" alt="LinkAja"><div class="pm-name">LinkAja</div></div>
            </label>
          </div>
        </div>
      </div>

      <!-- Virtual Account -->
      <div class="pm-accordion" id="acc-va">
        <div class="pm-accordion-header" onclick="toggleAcc('va')">
          <div class="pm-acc-left">
            <span style="font-size:1.1rem">🏦</span>
            <span>Virtual Account</span>
            <span class="pm-selected-badge" id="badge-va" style="display:none"></span>
          </div>
          <div class="chevron"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></div>
        </div>
        <div class="pm-accordion-body" id="body-va">
          <div class="payment-methods">
            <label class="payment-option"><input type="radio" name="channel" value="BRIVA" data-group="va" data-label="BRI VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/logo-bri.png" alt="BRI VA"><div class="pm-name">BRI VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="BCAVA" data-group="va" data-label="BCA VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/logo-bca.png" alt="BCA VA"><div class="pm-name">BCA VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="MANDIRIVA" data-group="va" data-label="Mandiri VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/logo-mandiri.png" alt="Mandiri VA"><div class="pm-name">Mandiri VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="BNIVA" data-group="va" data-label="BNI VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/logo-bni.png" alt="BNI VA"><div class="pm-name">BNI VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="BSI" data-group="va" data-label="BSI VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/bsi-syariah-indonesia.jpg" alt="BSI VA"><div class="pm-name">BSI VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="CIMBNIAGA" data-group="va" data-label="CIMB VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/logo-cimbniaga.png" alt="CIMB VA"><div class="pm-name">CIMB VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="DANAMON" data-group="va" data-label="Danamon VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/danamon-logo.png" alt="Danamon VA"><div class="pm-name">Danamon VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="PERMATAVA" data-group="va" data-label="Permata VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/logo-permata.png" alt="Permata VA"><div class="pm-name">Permata VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="MAYBANK" data-group="va" data-label="Maybank VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/myBank-va.png" alt="Maybank VA"><div class="pm-name">Maybank VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="BNCVA" data-group="va" data-label="BNC VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/Bank-Neo-Commerce.png" alt="BNC VA"><div class="pm-name">BNC VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="OCBC" data-group="va" data-label="OCBC VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/OCBC-bank.png" alt="OCBC VA"><div class="pm-name">OCBC VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="SINARMAS" data-group="va" data-label="Sinarmas VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/sinarmas%20bank.png" alt="Sinarmas VA"><div class="pm-name">Sinarmas VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="PANIN" data-group="va" data-label="Panin VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/Panin_Bank2.png" alt="Panin VA"><div class="pm-name">Panin VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="SAMPOERNAVA" data-group="va" data-label="Sahabat VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/sampoernava.jpg" alt="Sahabat VA"><div class="pm-name">Sahabat VA</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="ATMBERSAMA" data-group="va" data-label="ATM Bersama"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/ATM_Bersama.png" alt="ATM Bersama"><div class="pm-name">ATM Bersama</div></div></label>
            <label class="payment-option"><input type="radio" name="channel" value="ARTAGRAHA" data-group="va" data-label="Artagraha VA"><div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/Bank_Artha_Graha_Internasional.png" alt="Artagraha VA"><div class="pm-name">Artagraha VA</div></div></label>
          </div>
        </div>
      </div>

      <!-- Gerai Retail -->
      <div class="pm-accordion" id="acc-retail">
        <div class="pm-accordion-header" onclick="toggleAcc('retail')">
          <div class="pm-acc-left">
            <span style="font-size:1.1rem">🏪</span>
            <span>Gerai Retail</span>
            <span class="pm-selected-badge" id="badge-retail" style="display:none"></span>
          </div>
          <div class="chevron"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></div>
        </div>
        <div class="pm-accordion-body" id="body-retail">
          <div class="payment-methods">
            <label class="payment-option">
              <input type="radio" name="channel" value="ALFAMART" data-group="retail" data-label="Alfamart">
              <div class="pm-card"><img class="pm-logo" loading="lazy" decoding="async" src="https://violetmediapay.com/assets/img/pembayaran/logo-alfamart.png" alt="Alfamart"><div class="pm-name">Alfamart</div></div>
            </label>
          </div>
        </div>
      </div>

      <!-- Rincian total -->
      <div style="background:#f8f9ff;border-radius:8px;padding:14px;margin:20px 0;font-size:0.85rem">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px">
          <span style="color:var(--text-light)">Harga produk</span>
          <span style="font-weight:600">Rp <%= pending.baseAmount.toLocaleString('id-ID') %></span>
        </div>
        <% if(pending.addonAmount > 0) { %>
        <div style="display:flex;justify-content:space-between;margin-bottom:6px">
          <span style="color:var(--text-light)">Add-on (<%= pending.addonProductName %>)</span>
          <span style="font-weight:600">Rp <%= pending.addonAmount.toLocaleString('id-ID') %></span>
        </div>
        <% } %>
        <div style="display:flex;justify-content:space-between;margin-bottom:6px">
          <span style="color:var(--text-light)">Fee Platform</span>
          <span id="fee-display" style="color:var(--text-light)">— Pilih metode</span>
        </div>
        <hr style="border:none;border-top:1px solid var(--border);margin:8px 0">
        <div style="display:flex;justify-content:space-between;font-weight:800;font-size:1rem">
          <span>Total</span>
          <span style="color:var(--primary)" id="total-display">Rp <%= pending.amount.toLocaleString('id-ID') %></span>
        </div>
      </div>

      <button type="submit" class="btn-submit">🔒 Bayar Sekarang</button>
    </form>
  </div>
</div>

<script>
const BASE_AMOUNT = <%= pending.amount %>;

const FEE_CONFIG = {
  'QRIS':        { type: 'pct_flat', pct: 0.007,   flat: 1000, label: '0.7% + Rp 1.000' },
  'DANA':        { type: 'pct_flat', pct: 0.0167,  flat: 1500, label: '1.67% + Rp 1.500' },
  'OVO':         { type: 'pct_flat', pct: 0.0303,  flat: 500,  label: '3.03% + Rp 500' },
  'Shopee Pay':  { type: 'pct_flat', pct: 0.04,    flat: 500,  label: '4% + Rp 500' },
  'Link Aja':    { type: 'pct_flat', pct: 0.0167,  flat: 500,  label: '1.67% + Rp 500' },
  'BRIVA':       { type: 'flat', value: 3000,  label: 'Rp 3.000' },
  'BCAVA':       { type: 'flat', value: 4500,  label: 'Rp 4.500' },
  'MANDIRIVA':   { type: 'flat', value: 3000,  label: 'Rp 3.000' },
  'BNIVA':       { type: 'flat', value: 3500,  label: 'Rp 3.500' },
  'BSI':         { type: 'flat', value: 3500,  label: 'Rp 3.500' },
  'CIMBNIAGA':   { type: 'flat', value: 3500,  label: 'Rp 3.500' },
  'DANAMON':     { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'PERMATAVA':   { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'MAYBANK':     { type: 'flat', value: 4500,  label: 'Rp 4.500' },
  'BNCVA':       { type: 'flat', value: 4500,  label: 'Rp 4.500' },
  'OCBC':        { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'SINARMAS':    { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'PANIN':       { type: 'flat', value: 3500,  label: 'Rp 3.500' },
  'SAMPOERNAVA': { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'ATMBERSAMA':  { type: 'flat', value: 4500,  label: 'Rp 4.500' },
  'ARTAGRAHA':   { type: 'flat', value: 2500,  label: 'Rp 2.500' },
  'ALFAMART':    { type: 'flat', value: 3500,  label: 'Rp 3.500' },
};

function toggleAcc(id) {
  const header = document.querySelector('#acc-' + id + ' .pm-accordion-header');
  const body = document.getElementById('body-' + id);
  const isOpen = body.classList.contains('open');
  header.classList.toggle('open', !isOpen);
  body.classList.toggle('open', !isOpen);
}

function formatRp(n) {
  return 'Rp ' + Math.round(n).toLocaleString('id-ID');
}

document.querySelectorAll('input[name="channel"]').forEach(radio => {
  radio.addEventListener('change', function() {
    document.querySelectorAll('[id^="badge-"]').forEach(b => b.style.display = 'none');
    const group = this.dataset.group;
    const label = this.dataset.label;
    if (group && label) {
      const badge = document.getElementById('badge-' + group);
      if (badge) { badge.textContent = label; badge.style.display = 'inline'; }
    }
    const cfg = FEE_CONFIG[this.value];
    if (!cfg) return;
    const fee = cfg.type === 'pct_flat'
      ? Math.round(BASE_AMOUNT * cfg.pct) + cfg.flat
      : cfg.value;
    document.getElementById('fee-display').textContent = formatRp(fee) + ' (' + cfg.label + ')';
    document.getElementById('fee-display').style.color = '#374151';
    document.getElementById('total-display').textContent = formatRp(BASE_AMOUNT + fee);
  });
});
</script>

<script>
(function() {
  const KEY = 'checkout_timer_<%= product.slug %>';
  const DURATION = 15 * 60;
  let end = parseInt(sessionStorage.getItem(KEY) || '0');
  if (!end || end < Date.now() / 1000) {
    end = Math.floor(Date.now() / 1000) + DURATION;
    sessionStorage.setItem(KEY, end);
  }
  function tick() {
    const left = Math.max(0, end - Math.floor(Date.now() / 1000));
    const m = String(Math.floor(left / 60)).padStart(2, '0');
    const s = String(left % 60).padStart(2, '0');
    const el = document.getElementById('timer-display');
    const wrap = document.getElementById('checkout-timer');
    if (el) el.textContent = m + ':' + s;
    if (left <= 60 && wrap) wrap.style.background = '#fee2e2', wrap.style.borderColor = '#ef4444', wrap.style.color = '#991b1b';
    if (left === 0) { sessionStorage.removeItem(KEY); window.location.href = '/'; }
  }
  tick();
  setInterval(tick, 1000);
})();
</script>
<footer style="margin-top:60px">
  <p>&copy; 2026 <strong><%= settings.store_name %></strong></p>
</footer>
</body></html>
