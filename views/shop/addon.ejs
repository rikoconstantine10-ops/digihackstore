<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tambah Add-on - <%= settings.store_name || 'Digihack Store' %></title>
  <style>:root{--primary:#6c63ff;--text:#2d3748;--text-light:#718096;--text-dark:#1a202c;--border:#e2e8f0;--card:#fff;--radius:12px}*{box-sizing:border-box;margin:0;padding:0}body{font-family:'Inter',-apple-system,sans-serif;background:#f7f8fc;color:var(--text)}a{text-decoration:none;color:inherit}img{max-width:100%}</style>
  <link rel="preload" href="/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/css/style.css"></noscript>
  <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'"><noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
  <% if(settings && settings.meta_pixel_id) { %><script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= settings.meta_pixel_id %>');fbq('track','PageView');</script><% } %>
  <% if(settings && settings.ga4_id) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.ga4_id %>"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","<%= settings.ga4_id %>");</script>
  <% } %>
  <style>
    .addon-wrap { max-width: 680px; margin: 0 auto; padding: 20px 16px 60px; }
    .addon-header { text-align: center; padding: 32px 20px 24px; }
    .addon-header h1 { font-size: 1.5rem; font-weight: 800; margin: 0 0 8px; }
    .addon-header p { color: var(--text-light); margin: 0; font-size: 0.9rem; }
    .main-product-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 16px 20px; margin-bottom: 24px; display: flex; gap: 14px; align-items: center; }
    .main-product-card img { width: 64px; height: 64px; object-fit: cover; border-radius: 8px; flex-shrink: 0; }
    .main-product-card .icon { width: 64px; height: 64px; background: #e0e7ff; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; flex-shrink: 0; }
    .main-product-info h3 { margin: 0 0 4px; font-size: 1rem; font-weight: 700; }
    .main-product-info .price { color: var(--primary); font-weight: 700; font-size: 1rem; }
    .section-title { font-size: 1rem; font-weight: 700; margin-bottom: 14px; color: var(--text-dark); }
    /* Addon cards */
    .addon-card { border: 2px solid var(--border); border-radius: 14px; margin-bottom: 12px; cursor: pointer; transition: all 0.18s; background: var(--card); overflow: hidden; user-select: none; }
    .addon-card:hover { border-color: #a5b4fc; box-shadow: 0 4px 18px rgba(102,126,234,0.14); transform: translateY(-1px); }
    .addon-card.selected { border-color: var(--primary); background: #f5f3ff; box-shadow: 0 4px 20px rgba(102,126,234,0.22); }
    .addon-card-inner { display: flex; align-items: stretch; }
    .addon-card-img { width: 90px; height: 90px; object-fit: cover; flex-shrink: 0; }
    .addon-card-icon { width: 90px; height: 90px; background: linear-gradient(135deg, #e0e7ff, #f0f0ff); display: flex; align-items: center; justify-content: center; font-size: 2.2rem; flex-shrink: 0; }
    .addon-card-body { flex: 1; padding: 14px 14px; display: flex; flex-direction: column; justify-content: center; min-width: 0; }
    .addon-card-body h4 { margin: 0 0 8px; font-size: 0.92rem; font-weight: 700; line-height: 1.35; }
    .addon-price-row { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
    .addon-price-main { font-size: 1rem; font-weight: 800; color: #10b981; }
    .addon-price-old { font-size: 0.75rem; color: var(--text-light); text-decoration: line-through; }
    .addon-save-badge { font-size: 0.63rem; background: #dcfce7; color: #16a34a; padding: 2px 7px; border-radius: 10px; font-weight: 700; }
    .addon-card-check-wrap { width: 44px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-left: 1px solid #e8ecf4; background: #f8faff; transition: all 0.18s; }
    .addon-card.selected .addon-card-check-wrap { background: var(--primary); border-left-color: var(--primary); }
    .addon-check-box { width: 22px; height: 22px; border: 2.5px solid #cbd5e1; border-radius: 6px; display: flex; align-items: center; justify-content: center; transition: all 0.18s; font-size: 0.75rem; color: transparent; background: white; }
    .addon-card.selected .addon-check-box { border-color: white; background: white; color: var(--primary); font-weight: 800; }
    /* Actions */
    .addon-actions { margin-top: 24px; display: flex; flex-direction: column; gap: 10px; }
    .btn-add-addon { width: 100%; padding: 15px; background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; border-radius: 12px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.2s; display: none; box-shadow: 0 4px 16px rgba(102,99,255,0.3); }
    .btn-add-addon:hover { opacity: 0.92; transform: translateY(-1px); }
    .btn-skip { width: 100%; padding: 13px; background: transparent; color: var(--text-light); border: 1.5px solid var(--border); border-radius: 12px; font-size: 0.88rem; font-weight: 500; cursor: pointer; transition: all 0.2s; }
    .btn-skip:hover { color: var(--text-dark); border-color: #94a3b8; background: #f8faff; }
    /* Steps */
    .steps { display: flex; justify-content: center; gap: 8px; margin-bottom: 24px; align-items: center; font-size: 0.8rem; color: var(--text-light); }
    .step { display: flex; align-items: center; gap: 4px; }
    .step-num { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; }
    .step.done .step-num { background: #10b981; color: white; }
    .step.active .step-num { background: var(--primary); color: white; }
    .step.inactive .step-num { background: #e2e8f0; color: #94a3b8; }
    .step-line { width: 24px; height: 2px; background: #e2e8f0; }
    .multi-hint { font-size: 0.78rem; color: var(--text-light); margin-bottom: 14px; text-align: center; }
    @media(max-width:480px){
      .addon-wrap{padding:12px 12px 60px}
      .addon-header h1{font-size:1.2rem}
      .addon-card-img,.addon-card-icon{width:72px;height:72px}
      .addon-card-body{padding:10px}
      .addon-card-body h4{font-size:.85rem}
      .addon-price-main{font-size:.9rem}
      .main-product-card{padding:12px}
      .btn-add-addon,.btn-skip{padding:13px}
    }
  </style>
</head>
<body>
  <% if(settings && settings.meta_pixel_id) { %>
  <script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= settings.meta_pixel_id %>');fbq('track','PageView');</script>
  <% } %>

  <div class="addon-wrap">
    <div class="addon-header">
      <div class="steps">
        <div class="step done"><div class="step-num">✓</div><span>Data</span></div>
        <div class="step-line"></div>
        <div class="step active"><div class="step-num">2</div><span>Add-on</span></div>
        <div class="step-line"></div>
        <div class="step inactive"><div class="step-num">3</div><span>Bayar</span></div>
      </div>
      <h1>🎁 Lengkapi Pesanan Kamu</h1>
      <p>Tambahkan produk pendamping dengan harga spesial sebelum lanjut ke pembayaran</p>
    </div>

    <div class="main-product-card">
      <% if(product.image) { %>
      <img src="<%= product.image %>" alt="<%= product.name %>">
      <% } else { %>
      <div class="icon">📦</div>
      <% } %>
      <div class="main-product-info">
        <div style="font-size:0.75rem;color:var(--text-light);margin-bottom:2px">Produk yang kamu pilih:</div>
        <h3><%= product.name %></h3>
        <div class="price">Rp <%= (pending.amount).toLocaleString('id-ID') %></div>
      </div>
    </div>

    <div class="section-title">Produk add-on yang tersedia:</div>
    <div class="multi-hint">Pilih satu atau lebih add-on yang kamu inginkan</div>

    <form method="POST" action="/checkout/<%= product.slug %>/addon" id="addonForm">
      <div id="addonHiddenInputs"></div>

      <% addons.forEach(addon => { %>
      <% const addonPrice = addon.addon_price || addon.discount_price || addon.price; %>
      <% const basePrice = addon.discount_price || addon.price; %>
      <div class="addon-card" onclick="toggleAddon(<%= addon.id %>)" id="addon-card-<%= addon.id %>">
        <div class="addon-card-inner">
          <% if(addon.image) { %>
          <img class="addon-card-img" src="<%= addon.image %>" alt="<%= addon.name %>">
          <% } else { %>
          <div class="addon-card-icon">🎁</div>
          <% } %>
          <div class="addon-card-body">
            <h4><%= addon.name %></h4>
            <div class="addon-price-row">
              <span class="addon-price-main">+ Rp <%= addonPrice.toLocaleString('id-ID') %></span>
              <% if(addonPrice < basePrice) { %>
              <span class="addon-price-old">Rp <%= basePrice.toLocaleString('id-ID') %></span>
              <span class="addon-save-badge">Hemat!</span>
              <% } %>
            </div>
          </div>
          <div class="addon-card-check-wrap">
            <div class="addon-check-box" id="check-<%= addon.id %>">✓</div>
          </div>
        </div>
      </div>
      <% }) %>

      <% if(typeof error !== 'undefined' && error) { %>
      <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-weight:600">❌ <%= error %></div>
      <% } %>

      <div class="addon-actions">
        <button type="submit" class="btn-add-addon" id="btnAddAddon">✅ Tambahkan ke Pesanan</button>
        <button type="button" class="btn-skip" onclick="skipAddon()">Tidak, lanjutkan tanpa add-on →</button>
      </div>
    </form>
  </div>

  <script>
    const selectedIds = new Set();

    function toggleAddon(id) {
      const card = document.getElementById('addon-card-' + id);
      if (selectedIds.has(id)) {
        selectedIds.delete(id);
        card.classList.remove('selected');
      } else {
        selectedIds.add(id);
        card.classList.add('selected');
      }
      updateHiddenInputs();
      updateButton();
    }

    function updateHiddenInputs() {
      const container = document.getElementById('addonHiddenInputs');
      container.innerHTML = '';
      selectedIds.forEach(function(sid) {
        const inp = document.createElement('input');
        inp.type = 'hidden';
        inp.name = 'addon_product_id[]';
        inp.value = sid;
        container.appendChild(inp);
      });
    }

    function updateButton() {
      const btn = document.getElementById('btnAddAddon');
      if (selectedIds.size > 0) {
        btn.style.display = 'block';
        btn.textContent = selectedIds.size === 1
          ? '✅ Tambahkan 1 Add-on ke Pesanan'
          : '✅ Tambahkan ' + selectedIds.size + ' Add-on ke Pesanan';
      } else {
        btn.style.display = 'none';
      }
    }

    function skipAddon() {
      document.getElementById('addonForm').submit();
    }
  </script>
</body>
</html>
