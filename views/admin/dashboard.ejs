<!DOCTYPE html><html lang="id"><head><meta charset="UTF-8"><title>Dashboard - Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script></head>
<body>
<div class="admin-wrap">
  <aside class="admin-sidebar">
    <div class="admin-logo">🚀 Digihack</div>
    <nav class="admin-nav">
      <a href="/admin" class="active">📊 Dashboard</a>
      <a href="/admin/products">📦 Produk</a>
      <a href="/admin/orders">📝 Orders</a>
      <a href="/admin/leads">🎯 Leads</a>
      <a href="/admin/analytics">📈 Analytics</a>
      <a href="/admin/funnel">📊 Funnel</a>
      <a href="/admin/settings">⚙️ Settings</a>
      <a href="/admin/wa">💬 WhatsApp</a>
      <a href="/" target="_blank">🌍 Lihat Store</a>
      <a href="/admin/logout" style="margin-top:auto;color:#fc8181">🚪 Logout</a>
    </nav>
  </aside>
  <main class="admin-main">
    <div class="admin-topbar">
      <h1>📊 Dashboard</h1>
      <span style="color:var(--text-light);font-size:0.85rem">Halo, <strong><%= admin.username %></strong></span>
    </div>
    <div class="admin-content">
      <div class="stat-grid">
        <div class="stat-card"><div class="stat-icon">💰</div><div class="stat-label">Total Revenue</div><div class="stat-value" style="font-size:1.4rem">Rp <%= stats.revenue.toLocaleString('id-ID') %></div></div>
        <div class="stat-card"><div class="stat-icon">✅</div><div class="stat-label">Order Sukses</div><div class="stat-value"><%= stats.success_orders %></div></div>
        <div class="stat-card"><div class="stat-icon">⏳</div><div class="stat-label">Order Pending</div><div class="stat-value"><%= stats.pending_orders %></div></div>
        <div class="stat-card"><div class="stat-icon">📦</div><div class="stat-label">Total Produk</div><div class="stat-value"><%= stats.total_products %></div></div>
        <div class="stat-card"><div class="stat-icon">📝</div><div class="stat-label">Total Orders</div><div class="stat-value"><%= stats.total_orders %></div></div>
        <div class="stat-card"><div class="stat-icon">👁</div><div class="stat-label">Visitor Hari Ini</div><div class="stat-value"><%= stats.today_views %></div><div style="font-size:0.75rem;color:var(--text-light);margin-top:4px"><a href="/admin/analytics" style="color:var(--primary)">Lihat analytics →</a></div></div>
        <div class="stat-card"><div class="stat-icon">🟢</div><div class="stat-label">Online Sekarang</div><div class="stat-value" style="color:#10b981"><%= realtimeVisitors %></div><div style="font-size:0.75rem;color:var(--text-light);margin-top:4px">5 menit terakhir</div></div>
      </div>

      <div class="admin-table" style="margin-bottom:24px">
        <div style="padding:16px 20px;font-weight:700;border-bottom:1px solid var(--border)">💹 Revenue 7 Hari Terakhir</div>
        <div style="padding:20px"><canvas id="revenueChart" height="80"></canvas></div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px">
        <div class="admin-table">
          <div style="padding:16px 20px;font-weight:700;border-bottom:1px solid var(--border)">🏆 Top Produk (by Views)</div>
          <table>
            <thead><tr><th>Produk</th><th style="text-align:center">👁 Views</th><th style="text-align:center">✅ Sales</th></tr></thead>
            <tbody>
            <% topProducts.forEach(p => { %>
            <tr>
              <td style="font-size:0.85rem"><div style="font-weight:600"><%= p.name %></div></td>
              <td style="text-align:center;font-weight:700;color:var(--primary)"><%= p.views %></td>
              <td style="text-align:center;font-weight:700;color:#10b981"><%= p.sales %></td>
            </tr>
            <% }) %>
            <% if (!topProducts.length) { %><tr><td colspan="3" style="text-align:center;color:var(--text-light);padding:16px">Belum ada produk</td></tr><% } %>
            </tbody>
          </table>
        </div>

        <div class="admin-table">
          <div style="padding:16px 20px;font-weight:700;border-bottom:1px solid var(--border)">🕒 Order Terbaru</div>
          <table>
            <thead><tr><th>Ref</th><th>Produk</th><th>Amount</th><th>Status</th></tr></thead>
            <tbody>
            <% recent.slice(0,5).forEach(o => { %>
            <tr>
              <td><code style="font-size:0.72rem">#<%= o.ref_kode %></code></td>
              <td style="font-size:0.82rem;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= o.product_name %></td>
              <td style="font-weight:700;font-size:0.82rem">Rp <%= o.amount.toLocaleString('id-ID') %></td>
              <td><span class="badge badge-<%= o.status %>"><%= o.status %></span></td>
            </tr>
            <% }) %>
            </tbody>
          </table>
          <div style="padding:10px 16px;text-align:right"><a href="/admin/orders" style="color:var(--primary);font-size:0.82rem">Lihat semua →</a></div>
        </div>
      </div>

      <div class="admin-table">
        <div style="padding:16px 20px;font-weight:700;border-bottom:1px solid var(--border)">📋 Semua Order Terbaru</div>
        <table>
          <thead><tr><th>Ref</th><th>Produk</th><th>Customer</th><th>Amount</th><th>Metode</th><th>Status</th><th>Waktu</th></tr></thead>
          <tbody>
          <% recent.forEach(o => { %>
          <tr>
            <td><code style="font-size:0.75rem">#<%= o.ref_kode %></code></td>
            <td><%= o.product_name %></td>
            <td><div><%= o.customer_name %></div><div style="font-size:0.75rem;color:var(--text-light)"><%= o.customer_email %></div></td>
            <td style="font-weight:700">Rp <%= o.amount.toLocaleString('id-ID') %></td>
            <td><span style="font-size:0.8rem"><%= o.payment_method %></span></td>
            <td><span class="badge badge-<%= o.status %>"><%= o.status %></span></td>
            <td style="font-size:0.75rem;color:var(--text-light)"><%= o.created_at.slice(0,16) %></td>
          </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<script>
const revenueData = <%- JSON.stringify(revenueDaily) %>;
new Chart(document.getElementById('revenueChart').getContext('2d'), {
  type: 'bar',
  data: {
    labels: revenueData.map(d => d.day),
    datasets: [{ label: 'Revenue', data: revenueData.map(d => d.revenue), backgroundColor: 'rgba(108,99,255,0.7)', borderColor: '#6c63ff', borderWidth: 1, borderRadius: 6 }]
  },
  options: {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: { y: { beginAtZero: true, ticks: { callback: v => 'Rp ' + Number(v).toLocaleString('id-ID') } } }
  }
});
</script>
</body></html>