<!DOCTYPE html><html lang="id"><head><meta charset="UTF-8"><title>Produk - Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<style>
.prod-list { background:#fff; border-radius:14px; box-shadow:var(--shadow); }
.prod-cols { grid-template-columns:36px 56px 1fr 120px 80px 70px 130px; }
.prod-list-header { display:grid; padding:10px 16px; background:#f8faff; border-bottom:1px solid var(--border); font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:var(--text-light); align-items:center; gap:10px; border-radius:14px 14px 0 0; }
.prod-row { display:grid; padding:10px 16px; border-bottom:1px solid #f1f5f9; align-items:center; gap:10px; transition:background .15s; }
.prod-row:hover { background:#fafbff; }
.prod-row:last-child { border-bottom:none; }
.prod-num { font-size:0.82rem; font-weight:700; color:var(--text-light); text-align:center; }
.prod-thumb { width:48px; height:48px; object-fit:cover; border-radius:8px; }
.prod-thumb-placeholder { width:48px; height:48px; background:#e0e7ff; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:1.2rem; }
.prod-name { font-weight:700; font-size:0.88rem; color:var(--text); line-height:1.3; }
.prod-badges { display:flex; gap:4px; margin-top:3px; flex-wrap:wrap; align-items:center; }
.tag { display:inline-block; padding:2px 7px; border-radius:20px; font-size:0.63rem; font-weight:700; text-transform:uppercase; }
.tag-cat { background:#e0e7ff; color:#4338ca; }
.tag-new { background:#e0f2fe; color:#0284c7; }
.tag-hot { background:#fee2e2; color:#dc2626; }
.tag-sale { background:#fef3c7; color:#d97706; }
.tag-best { background:#dcfce7; color:#16a34a; }
.stat-pill { display:inline-flex; gap:8px; font-size:0.7rem; color:var(--text-light); margin-top:3px; }
.prod-price { font-weight:800; color:var(--primary); font-size:0.9rem; white-space:nowrap; }
.prod-price-old { text-decoration:line-through; color:var(--text-light); font-size:0.73rem; }
.status-dot { display:inline-flex; align-items:center; gap:5px; font-size:0.78rem; font-weight:600; }
.status-dot::before { content:''; width:7px; height:7px; border-radius:50%; flex-shrink:0; }
.status-active::before { background:#22c55e; }
.status-inactive::before { background:#ef4444; }
.priority-input { width:52px; padding:5px 6px; border:1px solid var(--border); border-radius:6px; font-size:0.82rem; text-align:center; outline:none; }
.priority-input:focus { border-color:var(--primary); }
.action-wrap { display:flex; gap:5px; align-items:center; position:relative; }
.act-btn { padding:6px 10px; border-radius:7px; font-size:0.76rem; font-weight:600; cursor:pointer; border:none; white-space:nowrap; }
.act-edit { background:var(--primary); color:white; text-decoration:none; display:inline-flex; align-items:center; }
.act-more { background:#f1f5f9; color:var(--text); }
.act-more:hover { background:#e2e8f0; }
.dropdown { position:absolute; right:0; top:calc(100% + 4px); background:white; border-radius:10px; box-shadow:0 8px 30px rgba(0,0,0,0.15); z-index:200; min-width:155px; overflow:hidden; display:none; }
.dropdown.open { display:block; }
.dropdown a, .dropdown button { display:flex; align-items:center; gap:8px; width:100%; padding:9px 13px; font-size:0.82rem; font-weight:500; color:var(--text); border:none; background:none; cursor:pointer; text-decoration:none; }
.dropdown a:hover, .dropdown button:hover { background:#f8faff; }
.dropdown .danger { color:#dc2626; }
.dropdown .danger:hover { background:#fef2f2; }
</style>
</head>
<body>
<div class="admin-wrap">
  <aside class="admin-sidebar">
    <div class="admin-logo">🚀 Digihack</div>
    <nav class="admin-nav">
      <a href="/admin">📊 Dashboard</a>
      <a href="/admin/products" class="active">📦 Produk</a>
      <a href="/admin/orders">📝 Orders</a>
      <a href="/admin/leads">🎯 Leads</a>
      <a href="/admin/analytics">📈 Analytics</a>
      <a href="/admin/funnel">📊 Funnel</a>
      <a href="/admin/settings">⚙️ Settings</a>
      <a href="/admin/wa">💬 WhatsApp</a>
      <a href="/" target="_blank">🌍 Lihat Store</a>
      <a href="/admin/logout" style="margin-top:auto;color:#fc8181">🚪 Logout</a>
    </nav>
  </aside>
  <main class="admin-main">
    <div class="admin-topbar">
      <h1>📦 Produk</h1>
      <div style="display:flex;align-items:center;gap:12px">
        <% if(success) { %><span style="background:#dcfce7;color:#166534;padding:6px 14px;border-radius:8px;font-size:0.82rem;font-weight:600">✅ Disimpan!</span><% } %>
        <span style="color:var(--text-light);font-size:0.85rem">Halo, <strong><%= admin.username %></strong></span>
        <a href="/admin/products/new" class="admin-btn admin-btn-primary" style="padding:9px 18px;text-decoration:none;border-radius:9px">+ Produk Baru</a>
      </div>
    </div>
    <div class="admin-content">
      <div class="prod-list">
        <div class="prod-list-header prod-cols">
          <div style="text-align:center">#</div>
          <div>Gambar</div>
          <div>Produk</div>
          <div>Harga</div>
          <div>Status</div>
          <div style="text-align:center">Prior.</div>
          <div>Aksi</div>
        </div>
        <% products.forEach((p, i) => { %>
        <div class="prod-row prod-cols" id="row-<%= p.id %>">
          <div class="prod-num"><%= i+1 %></div>
          <div>
            <% if(p.image) { %>
            <img src="<%= p.image %>" class="prod-thumb" alt="<%= p.name %>">
            <% } else { %>
            <div class="prod-thumb-placeholder">📦</div>
            <% } %>
          </div>
          <div style="min-width:0">
            <div style="display:flex;align-items:center;gap:6px">
              <% if(p.is_pinned) { %><span title="Pinned" style="font-size:0.85rem">📌</span><% } %>
              <div class="prod-name" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= p.name %></div>
            </div>
            <div class="prod-badges">
              <span class="tag tag-cat"><%= p.category %></span>
              <% if(p.badge) { %><span class="tag tag-<%= p.badge.toLowerCase() %>"><%= p.badge %></span><% } %>
            </div>
            <div class="stat-pill"><span>👁 <%= p.view_count %></span><span>🛒 <%= p.checkout_count %></span><span>✅ <%= p.sales_count %></span></div>
          </div>
          <div>
            <div class="prod-price">Rp <%= (p.discount_price||p.price).toLocaleString('id-ID') %></div>
            <% if(p.discount_price) { %><div class="prod-price-old">Rp <%= p.price.toLocaleString('id-ID') %></div><% } %>
          </div>
          <div>
            <span class="status-dot <%= p.is_active ? 'status-active' : 'status-inactive' %>">
              <%= p.is_active ? 'Aktif' : 'Nonaktif' %>
            </span>
          </div>
          <div style="text-align:center">
            <input type="number" class="priority-input" value="<%= p.priority||0 %>" min="0"
              onchange="savePriority(<%= p.id %>, this.value)">
          </div>
          <div>
            <div class="action-wrap">
              <a href="/admin/products/edit/<%= p.id %>" class="act-btn act-edit">✏️ Edit</a>
              <button class="act-btn act-more" onclick="toggleDropdown(event, 'dd-<%= p.id %>')">▾</button>
              <div class="dropdown" id="dd-<%= p.id %>">
                <a href="/product/<%= p.slug %>" target="_blank">👁 Lihat Produk</a>
                <button onclick="copyLink('<%= p.slug %>')">🔗 Salin Link</button>
                <button onclick="togglePin(<%= p.id %>, this)" id="pin-btn-<%= p.id %>">
                  <%= p.is_pinned ? '📌 Unpin' : '📌 Pin ke Atas' %>
                </button>
                <form method="POST" action="/admin/products/duplicate/<%= p.id %>" style="margin:0">
                  <button type="submit">📋 Duplikat Produk</button>
                </form>
                <button onclick="toggleActive(<%= p.id %>)" class="<%= !p.is_active ? '' : 'danger' %>">
                  <%= p.is_active ? '⏸ Nonaktifkan' : '▶️ Aktifkan' %>
                </button>
                <form method="POST" action="/admin/products/delete/<%= p.id %>" onsubmit="return confirm('Nonaktifkan produk ini?')" style="margin:0">
                  <button type="submit" class="danger">🗑 Hapus</button>
                </form>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
        <% if(products.length === 0) { %>
        <div style="padding:48px;text-align:center;color:var(--text-light)">
          <div style="font-size:3rem;margin-bottom:12px">📦</div>
          <div style="font-weight:600;margin-bottom:8px">Belum ada produk</div>
          <a href="/admin/products/new" class="admin-btn admin-btn-primary" style="display:inline-block;margin-top:8px;text-decoration:none">+ Tambah Produk Pertama</a>
        </div>
        <% } %>
      </div>
    </div>
  </main>
</div>

<script>
function toggleDropdown(e, id) {
  e.stopPropagation();
  document.querySelectorAll('.dropdown.open').forEach(d => { if(d.id !== id) d.classList.remove('open'); });
  document.getElementById(id).classList.toggle('open');
}
document.addEventListener('click', () => document.querySelectorAll('.dropdown.open').forEach(d => d.classList.remove('open')));

function copyLink(slug) {
  navigator.clipboard.writeText(window.location.origin + '/product/' + slug).then(() => alert('✅ Link disalin!'));
}

function savePriority(id, val) {
  fetch('/admin/products/priority/' + id, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ priority: parseInt(val)||0 })
  });
}

function toggleActive(id) {
  fetch('/admin/products/toggle/' + id, { method: 'POST' })
    .then(r => r.json())
    .then(d => { if(d.success) location.reload(); });
}

function togglePin(id, btn) {
  fetch('/admin/products/pin/' + id, { method: 'POST' })
    .then(r => r.json())
    .then(d => { if(d.success) location.reload(); });
}
</script>
</body></html>
