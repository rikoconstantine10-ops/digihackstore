<!DOCTYPE html><html lang="id"><head><meta charset="UTF-8"><title>Produk - Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<style>
.ql-toolbar.ql-snow { border-radius: 8px 8px 0 0; border-color: #e2e8f0; background: #f8fafc; }
.ql-container.ql-snow { border-radius: 0 0 8px 8px; border-color: #e2e8f0; font-family: 'Inter', sans-serif; min-height: 90px; }
.ql-editor { min-height: 80px; font-size: 0.9rem; }
</style></head>
<body>
<div class="admin-wrap">
  <aside class="admin-sidebar">
    <div class="admin-logo">🚀 Digihack</div>
    <nav class="admin-nav">
      <a href="/admin">📊 Dashboard</a>
      <a href="/admin/products" class="active">📦 Produk</a>
      <a href="/admin/orders">📝 Orders</a>
      <a href="/admin/analytics">📈 Analytics</a>
      <a href="/admin/settings">⚙️ Settings</a>
      <a href="/admin/wa">💬 WhatsApp</a>
      <a href="/" target="_blank">🌍 Lihat Store</a>
      <a href="/admin/logout" style="margin-top:auto;color:#fc8181">🚪 Logout</a>
    </nav>
  </aside>
  <main class="admin-main">
    <div class="admin-topbar">
      <h1>📦 Manajemen Produk</h1>
      <span style="color:var(--text-light);font-size:0.85rem">Halo, <strong><%= admin.username %></strong></span>
    </div>
    <div class="admin-content">

      <div class="form-admin">
        <h3>+ Tambah Produk Baru</h3>
        <form method="POST" action="/admin/products/add" enctype="multipart/form-data">
          <div class="form-row">
            <div class="form-group"><label>Nama Produk *</label><input type="text" name="name" required></div>
            <div class="form-group"><label>Kategori *</label><input type="text" name="category" placeholder="Contoh: Ebook, Software, Template" required></div>
          </div>
          <div class="form-group">
            <label>Deskripsi</label>
            <div id="addDescEditor"></div>
            <textarea name="description" id="addDescHidden" style="display:none"></textarea>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Harga Normal (Rp) *</label><input type="number" name="price" required min="1000"></div>
            <div class="form-group"><label>Harga Diskon (Rp) - opsional</label><input type="number" name="discount_price" min="1000"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Badge</label>
              <select name="badge"><option value="">Tidak ada</option><option value="new">NEW</option><option value="hot">HOT</option><option value="sale">SALE</option><option value="best">BEST</option></select>
            </div>
            <div class="form-group"><label>Countdown Diskon (opsional)</label><input type="datetime-local" name="countdown_end"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Gambar Produk</label><input type="file" name="image" accept="image/*"></div>
            <div class="form-group"><label>File Produk (PDF/ZIP/dll)</label><input type="file" name="file"></div>
          </div>

          <% if(allProducts.length > 0) { %>
          <div style="border-top:1px solid #e2e8f0;margin:16px 0;padding-top:16px">
            <h4 style="margin:0 0 8px;font-size:0.95rem;color:var(--text-dark)">🎁 Add-on Products (opsional)</h4>
            <div style="font-size:0.8rem;color:var(--text-light);margin-bottom:10px">Pilih produk yang akan ditawarkan sebagai add-on sebelum pembayaran. Isi harga override jika ingin berbeda dari harga produk asli.</div>
            <div id="addAddonList" style="display:flex;flex-direction:column;gap:8px;max-height:200px;overflow-y:auto">
              <% allProducts.forEach(ap => { %>
              <div style="display:flex;align-items:center;gap:10px;padding:8px 10px;border:1px solid #e2e8f0;border-radius:6px;background:#fafafa">
                <input type="checkbox" name="addon_ids[]" value="<%= ap.id %>" style="margin:0;cursor:pointer">
                <span style="flex:1;font-size:0.85rem"><%= ap.name %></span>
                <span style="font-size:0.75rem;color:var(--text-light)">Rp <%= (ap.discount_price||ap.price).toLocaleString('id-ID') %></span>
                <input type="number" name="addon_price_<%= ap.id %>" placeholder="Override harga" style="width:140px;padding:4px 8px;border:1px solid #e2e8f0;border-radius:4px;font-size:0.8rem" min="0">
              </div>
              <% }) %>
            </div>
          </div>
          <% } %>

          <button type="submit" class="admin-btn admin-btn-primary" style="padding:10px 24px">+ Tambah Produk</button>
        </form>
      </div>

      <div class="admin-table">
        <div style="padding:16px 20px;font-weight:700;border-bottom:1px solid var(--border)">
          Daftar Produk (<%= products.length %>)
          <span style="font-size:0.75rem;font-weight:400;color:var(--text-light);margin-left:12px">👁 = views &nbsp; 🛒 = checkout &nbsp; ✅ = terjual</span>
        </div>
        <table>
          <thead><tr><th>Gambar</th><th>Nama</th><th>Kategori</th><th>Harga</th><th style="text-align:center">👁</th><th style="text-align:center">🛒</th><th style="text-align:center">✅</th><th>Status</th><th>Aksi</th></tr></thead>
          <tbody>
          <% products.forEach(p => { %>
          <tr>
            <td><% if(p.image) { %><img src="<%= p.image %>" style="width:50px;height:40px;object-fit:cover;border-radius:6px"><% } else { %><div style="width:50px;height:40px;background:#e0e7ff;border-radius:6px;display:flex;align-items:center;justify-content:center">📦</div><% } %></td>
            <td>
              <div style="font-weight:600"><%= p.name %></div>
              <div style="font-size:0.75rem;color:var(--text-light)"><%= p.slug %></div>
              <% if(p.badge) { %><span class="badge badge-<%= p.badge %>"><%= p.badge %></span><% } %>
            </td>
            <td><%= p.category %></td>
            <td>
              <div style="font-weight:700;color:var(--primary)">Rp <%= (p.discount_price||p.price).toLocaleString('id-ID') %></div>
              <% if(p.discount_price) { %><div style="text-decoration:line-through;font-size:0.75rem;color:var(--text-light)">Rp <%= p.price.toLocaleString('id-ID') %></div><% } %>
            </td>
            <td style="text-align:center;font-weight:700;color:var(--primary)"><%= p.view_count || 0 %></td>
            <td style="text-align:center;font-weight:700;color:#f59e0b"><%= p.checkout_count || 0 %></td>
            <td style="text-align:center;font-weight:700;color:#10b981"><%= p.sales_count || 0 %></td>
            <td><span class="badge <%= p.is_active ? 'badge-success' : 'badge-expired' %>"><%= p.is_active ? 'Aktif' : 'Nonaktif' %></span></td>
            <td style="display:flex;gap:6px;flex-wrap:wrap">
              <a href="/product/<%= p.slug %>" target="_blank"><button class="admin-btn" style="background:#e0e7ff;color:var(--primary)">👁</button></a>
              <button onclick="copyLink('<%= p.slug %>')" class="admin-btn" style="background:#f0fdf4;color:#16a34a" title="Copy link produk">🔗</button>
              <button onclick="editProduct(<%= JSON.stringify(p) %>)" class="admin-btn admin-btn-primary">✏️</button>
              <form method="POST" action="/admin/products/delete/<%= p.id %>" style="margin:0" onsubmit="return confirm('Nonaktifkan produk ini?')">
                <button type="submit" class="admin-btn admin-btn-danger">🗑</button>
              </form>
            </td>
          </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<div id="editModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
  <div style="background:white;border-radius:16px;padding:32px;width:600px;max-width:90vw;max-height:90vh;overflow-y:auto">
    <h3 style="margin-bottom:20px">Edit Produk</h3>
    <form id="editForm" method="POST" enctype="multipart/form-data">
      <div class="form-row">
        <div class="form-group"><label>Nama *</label><input type="text" name="name" id="editName" required></div>
        <div class="form-group"><label>Kategori *</label><input type="text" name="category" id="editCategory" required></div>
      </div>
      <div class="form-group">
        <label>Deskripsi</label>
        <div id="editDescEditor"></div>
        <textarea name="description" id="editDesc" style="display:none"></textarea>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Harga Normal</label><input type="number" name="price" id="editPrice" required></div>
        <div class="form-group"><label>Harga Diskon</label><input type="number" name="discount_price" id="editDiscountPrice"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Badge</label><select name="badge" id="editBadge"><option value="">Tidak ada</option><option value="new">NEW</option><option value="hot">HOT</option><option value="sale">SALE</option><option value="best">BEST</option></select></div>
        <div class="form-group"><label>Countdown End</label><input type="datetime-local" name="countdown_end" id="editCountdown"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Gambar baru (opsional)</label><input type="file" name="image" accept="image/*"></div>
        <div class="form-group"><label>File baru (opsional)</label><input type="file" name="file"></div>
      </div>
      <div class="form-group"><label><input type="checkbox" name="is_active" id="editActive" value="1"> Aktif</label></div>

      <div style="border-top:1px solid #e2e8f0;margin:20px 0;padding-top:16px">
        <h4 style="margin:0 0 12px;font-size:0.95rem;color:var(--text-dark)">🎁 Add-on Products</h4>
        <div style="font-size:0.8rem;color:var(--text-light);margin-bottom:12px">Pilih produk yang akan ditawarkan sebagai add-on sebelum pembayaran. Isi harga override jika berbeda dari harga produk.</div>
        <div id="addonList" style="display:flex;flex-direction:column;gap:8px;max-height:200px;overflow-y:auto">
          <% allProducts.forEach(ap => { %>
          <div class="addon-item" data-pid="<%= ap.id %>" style="display:flex;align-items:center;gap:10px;padding:8px 10px;border:1px solid #e2e8f0;border-radius:6px;background:#fafafa">
            <input type="checkbox" class="addon-check" name="addon_ids[]" value="<%= ap.id %>" style="margin:0;cursor:pointer">
            <span style="flex:1;font-size:0.85rem"><%= ap.name %></span>
            <span style="font-size:0.75rem;color:var(--text-light)">Rp <%= (ap.discount_price||ap.price).toLocaleString('id-ID') %></span>
            <input type="number" name="addon_price_<%= ap.id %>" class="addon-price" placeholder="Override harga" style="width:140px;padding:4px 8px;border:1px solid #e2e8f0;border-radius:4px;font-size:0.8rem" min="0">
          </div>
          <% }) %>
        </div>
      </div>

      <div style="display:flex;gap:10px">
        <button type="submit" class="admin-btn admin-btn-primary" style="padding:10px 24px">Simpan</button>
        <button type="button" onclick="document.getElementById('editModal').style.display='none'" class="admin-btn" style="padding:10px 24px;background:#e2e8f0">Batal</button>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
const toolbarOptions = [
  [{ 'header': [1, 2, 3, false] }],
  ['bold', 'italic', 'underline'],
  [{ 'color': [] }],
  [{ 'list': 'ordered' }, { 'list': 'bullet' }],
  ['clean']
];

// Quill for ADD form
const addQuill = new Quill('#addDescEditor', { theme: 'snow', modules: { toolbar: toolbarOptions }, placeholder: 'Tulis deskripsi produk...' });

// Quill for EDIT modal
const editQuill = new Quill('#editDescEditor', { theme: 'snow', modules: { toolbar: toolbarOptions }, placeholder: 'Tulis deskripsi produk...' });

// Sync Quill content to hidden textarea before form submit
document.querySelector('form[action="/admin/products/add"]').addEventListener('submit', function() {
  document.getElementById('addDescHidden').value = addQuill.root.innerHTML;
});
document.getElementById('editForm').addEventListener('submit', function() {
  document.getElementById('editDesc').value = editQuill.root.innerHTML;
});

function copyLink(slug) {
  const url = window.location.origin + '/product/' + slug;
  navigator.clipboard.writeText(url).then(() => {
    alert('✅ Link disalin!\n' + url);
  }).catch(() => {
    prompt('Salin link ini:', url);
  });
}

function editProduct(p) {
  document.getElementById('editName').value = p.name;
  document.getElementById('editCategory').value = p.category;
  editQuill.root.innerHTML = p.description || '';
  document.getElementById('editDesc').value = p.description || '';
  document.getElementById('editPrice').value = p.price;
  document.getElementById('editDiscountPrice').value = p.discount_price || '';
  document.getElementById('editBadge').value = p.badge || '';
  document.getElementById('editCountdown').value = p.countdown_end || '';
  document.getElementById('editActive').checked = p.is_active === 1;
  document.getElementById('editForm').action = '/admin/products/edit/' + p.id;

  const addonMap = {};
  (p.addons || []).forEach(a => { addonMap[a.addon_product_id] = a.addon_price; });
  document.querySelectorAll('.addon-item').forEach(row => {
    const pid = parseInt(row.dataset.pid);
    const isself = pid === p.id;
    row.style.display = isself ? 'none' : 'flex';
    const chk = row.querySelector('.addon-check');
    const priceInput = row.querySelector('.addon-price');
    if (isself) { chk.checked = false; priceInput.value = ''; return; }
    const hasAddon = addonMap.hasOwnProperty(pid);
    chk.checked = hasAddon;
    priceInput.value = hasAddon && addonMap[pid] ? addonMap[pid] : '';
  });

  document.getElementById('editModal').style.display = 'flex';
}
</script>
</body></html>