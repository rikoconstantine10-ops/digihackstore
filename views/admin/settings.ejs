<!DOCTYPE html><html lang="id"><head><meta charset="UTF-8"><title>Settings - Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="admin-wrap">
  <aside class="admin-sidebar">
    <div class="admin-logo">🚀 Digihack</div>
    <nav class="admin-nav">
      <a href="/admin">📊 Dashboard</a>
      <a href="/admin/products">📦 Produk</a>
      <a href="/admin/orders">📝 Orders</a>
      <a href="/admin/leads">🎯 Leads</a>
      <a href="/admin/analytics">📈 Analytics</a>
      <a href="/admin/funnel">📊 Funnel</a>
      <a href="/admin/settings" class="active">⚙️ Settings</a>
      <a href="/admin/wa">💬 WhatsApp</a>
      <a href="/" target="_blank">🌍 Lihat Store</a>
      <a href="/admin/logout" style="margin-top:auto;color:#fc8181">🚪 Logout</a>
    </nav>
  </aside>
  <main class="admin-main">
    <div class="admin-topbar">
      <h1>⚙️ Pengaturan Toko</h1>
      <span style="color:var(--text-light);font-size:0.85rem">Halo, <strong><%= admin.username %></strong></span>
    </div>
    <div class="admin-content">
      <% if(success) { %><div style="background:#dcfce7;color:#166534;padding:12px 16px;border-radius:8px;margin-bottom:20px;font-weight:600">✅ Pengaturan disimpan!</div><% } %>
      <form method="POST" action="/admin/settings">

        <div class="form-admin">
          <h3>🏪 Info Toko</h3>
          <div class="form-group">
            <label>Nama Toko</label>
            <input type="text" name="store_name" value="<%= settings.store_name || '' %>">
          </div>
          <div class="form-group">
            <label>Domain Store</label>
            <input type="text" name="store_domain" value="<%= settings.store_domain || '' %>" placeholder="https://digihackstore.com">
            <div style="font-size:0.8rem;color:var(--text-light)">Digunakan untuk Meta Conversions API & tracking. Tanpa trailing slash.</div>
          </div>
        </div>

        <div class="form-admin">
          <h3>📊 Google Analytics 4</h3>
          <div class="form-group">
            <label>GA4 Measurement ID</label>
            <input type="text" name="ga4_id" value="<%= settings.ga4_id || '' %>" placeholder="Contoh: G-XXXXXXXXXX">
            <div style="font-size:0.8rem;color:var(--text-light)">Kosongkan jika tidak menggunakan GA4. Didapat dari Google Analytics → Admin → Data Streams.</div>
          </div>
        </div>

        <div class="form-admin">
          <h3>📱 Meta Ads (Pixel & Conversions API)</h3>
          <div class="form-group">
            <label>Meta Pixel ID</label>
            <input type="text" name="meta_pixel_id" value="<%= settings.meta_pixel_id || '' %>" placeholder="Contoh: 123456789012345">
            <div style="font-size:0.8rem;color:var(--text-light)">Untuk browser-side tracking (PageView, ViewContent, InitiateCheckout, Purchase)</div>
          </div>
          <div class="form-group">
            <label>Meta Conversions API Token</label>
            <input type="text" name="meta_capi_token" value="<%= settings.meta_capi_token || '' %>" placeholder="EAAxxxxxxxxxxxxx...">
            <div style="font-size:0.8rem;color:var(--text-light)">Didapat dari Meta Business Manager → Events Manager → Settings → Conversions API. Untuk server-side tracking.</div>
          </div>
          <% if(!settings.meta_pixel_id || !settings.meta_capi_token) { %>
          <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:12px;font-size:0.82rem;color:#1e40af">
            💡 <strong>Tips:</strong> Isi keduanya (Pixel ID + CAPI Token) untuk deduplikasi event sempurna antara browser-tracking dan server-tracking. Event yang didukung: ViewContent, InitiateCheckout, Purchase.
          </div>
          <% } else { %>
          <div style="background:#dcfce7;border:1px solid #bbf7d0;border-radius:8px;padding:12px;font-size:0.82rem;color:#166534">
            ✅ Meta Pixel & Conversions API aktif. Event tracking: ViewContent, InitiateCheckout, Purchase.
          </div>
          <% } %>
        </div>

        <div class="form-admin">
          <h3>💬 WhatsApp Auto Follow-Up</h3>
          <div class="form-group">
            <label>Nomor WA Admin (dengan kode negara)</label>
            <input type="text" name="wa_number" value="<%= settings.wa_number || '' %>" placeholder="Contoh: 6281234567890">
          </div>
          <div class="form-group">
            <label>Pesan Follow-Up (setelah bayar sukses)</label>
            <textarea name="wa_followup_msg" rows="3" style="width:100%"><%= settings.wa_followup_msg || '' %></textarea>
            <div style="font-size:0.75rem;color:var(--text-light);margin-top:4px">Variabel: {name} {product} {email}</div>
          </div>
          <div class="form-group">
            <label>Pesan Reminder Pending Bayar</label>
            <textarea name="wa_pending_msg" rows="3" style="width:100%"><%= settings.wa_pending_msg || '' %></textarea>
            <div style="font-size:0.75rem;color:var(--text-light);margin-top:4px">Variabel: {name} {product} {expired} {url} — Dikirim otomatis 1 jam setelah order pending</div>
          </div>
          <div class="form-group">
            <label>Pesan Auto-Reminder Leads <span style="background:#fef3c7;color:#d97706;font-size:0.65rem;font-weight:700;padding:2px 8px;border-radius:10px;vertical-align:middle">AUTO 15 MENIT</span></label>
            <textarea name="wa_leads_msg" rows="4" style="width:100%;font-family:monospace;font-size:0.82rem"><%= settings.wa_leads_msg || 'Halo {name}! 👋\n\nKamu tadi sempat mau beli *{product}* di Digihack Store tapi sepertinya belum selesai.\n\nMasih minat? Yuk selesaikan ordernya sekarang, stok terbatas! 🔥\n\ndigihackstore.com' %></textarea>
            <div style="font-size:0.75rem;color:var(--text-light);margin-top:4px">Variabel: {name} {product} — Dikirim <strong>otomatis 15 menit</strong> setelah calon pembeli isi form tapi tidak lanjut bayar</div>
          </div>
        </div>

        <button type="submit" class="admin-btn admin-btn-primary" style="padding:12px 32px">Simpan Pengaturan</button>
      </form>
    </div>
  </main>
</div>
</body></html>
